class ConnectionLost(Exception):
    """SSH transport to the cluster failed or stalled (VPN drop, sleep/wake...)."""


def info(msg):
    # stderr: stdout is reserved for payload (--json, logs, tables) — a stale-
    # master or requeue notice must never corrupt machine-parsed output.
    # flush: backgrounded/piped runs (e.g. agents) must see progress promptly.
    print(f"hpc-alloc: {msg}", file=sys.stderr, flush=True)


def die(msg, code=1):
    print(f"hpc-alloc: error: {msg}", file=sys.stderr)
    sys.exit(code)


