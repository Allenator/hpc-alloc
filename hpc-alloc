def parse_toml_subset(text):
    """Minimal TOML for this config's shape — [dotted.sections] and
    key = "string" | integer | true/false. Fallback for Python < 3.11
    (no tomllib); keep the config file to this subset if your python3 is old."""
    data = {}
    section = data
    for ln, raw in enumerate(text.splitlines(), 1):
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            section = data
            for part in line[1:-1].split("."):
                section = section.setdefault(part.strip().strip('"'), {})
            continue
        key, eq, val = line.partition("=")
        key, val = key.strip(), val.strip()
        if not eq or not key or not val:
            die(f"{CONFIG_TOML} line {ln}: cannot parse: {raw}")
        if val[0] in "\"'":
            end = val.find(val[0], 1)
            if end < 0:
                die(f"{CONFIG_TOML} line {ln}: unterminated string: {raw}")
            section[key] = val[1:end]
            continue
        val = val.split("#", 1)[0].strip()
        if val.lower() in ("true", "false"):
            section[key] = val.lower() == "true"
            continue
        try:
            section[key] = int(val)
        except ValueError:
            die(f"{CONFIG_TOML} line {ln}: unsupported value (use the string/int/bool "
                f"subset for Python < 3.11): {raw}")
    return data


def load_config():
    if not CONFIG_TOML.exists():
        return {}
    text = CONFIG_TOML.read_text()
    try:
        import tomllib
    except ModuleNotFoundError:
        return parse_toml_subset(text)
    try:
        return tomllib.loads(text)
    except tomllib.TOMLDecodeError as e:
        die(f"invalid {CONFIG_TOML}: {e}")


CONFIG = load_config()


def cfg(*path, default=None):
    d = CONFIG
    for k in path:
        if not isinstance(d, dict) or k not in d:
            return default
        d = d[k]
    return d


def cfg_int(value, name):
    if value is None:
        return None
    try:
        return int(value)
    except (TypeError, ValueError):
        die(f"{CONFIG_TOML}: {name} must be an integer, got {value!r}")


def resolve_common(args):
    """Fill options the CLI left unset from config.toml, then built-ins."""
    if getattr(args, "cluster", "") is None:
        args.cluster = cfg("defaults", "cluster") or DEFAULT_CLUSTER
    if getattr(args, "time", "") is None:
        args.time = cfg("defaults", "time") or DEFAULT_TIME
    if getattr(args, "cpus", "") is None:
        args.cpus = cfg_int(cfg("defaults", "cpus"), "defaults.cpus") or DEFAULT_CPUS
    if getattr(args, "mem", "") is None:
        args.mem = cfg("defaults", "mem")


# ---------------------------------------------------------------- state

def load_state():
    if STATE_FILE.exists():
        with open(STATE_FILE) as f:
            return json.load(f)
    return {"netid": None, "clusters": {}, "allocs": {}}


def save_state(state):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    tmp = STATE_FILE.with_suffix(".tmp")
    with open(tmp, "w") as f:
        json.dump(state, f, indent=2)
    tmp.replace(STATE_FILE)
    STATE_FILE.chmod(0o600)
    rebuild_ssh_config(state)


@contextmanager
def locked_state():
    """Exclusive read-modify-write of state.json. Concurrent invocations are
    normal (a backgrounded `run` racing an interactive `up`), and last-writer-
    wins would silently drop allocation records. Keep network calls outside."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    lf = open(LOCK_FILE, "w")
    fcntl.flock(lf, fcntl.LOCK_EX)
    try:
        state = load_state()
        yield state
        save_state(state)
    finally:
        fcntl.flock(lf, fcntl.LOCK_UN)
        lf.close()


def require_setup(state):
    if not state.get("netid") or not state.get("clusters"):
        die("not configured yet — run `hpc-alloc setup --netid YOUR_NETID` first")


def login_alias(cluster):
    return f"{cluster}-login"


def alloc_alias(alloc):
    return f"{alloc['cluster']}-{alloc['name']}"


# ------------------------------------------------------- ssh config file

def rebuild_ssh_config(state):
    """Regenerate the managed ssh_config from state. Idempotent."""
    netid = state.get("netid") or "NETID"
    ident = cfg("ssh", "identity_file")
    id_lines = [f"    IdentityFile {ident}", "    IdentitiesOnly yes"] if ident else []
    lines = [
        "# Managed by hpc-alloc — regenerated on every change; do not edit by hand.",
        "",
    ]
    for cluster, ccfg in sorted(state.get("clusters", {}).items()):
        lines += [
            f"Host {login_alias(cluster)}",
            f"    HostName {ccfg['host']}",
            f"    User {netid}",
            *id_lines,
            "    ControlMaster auto",
            "    ControlPath ~/.ssh/hpc-alloc-%C",
            "    ControlPersist 4h",
            "    ServerAliveInterval 15",
            "    ServerAliveCountMax 3",
            "    StrictHostKeyChecking accept-new",
            "",
        ]
    for name, alloc in sorted(state.get("allocs", {}).items()):
        if not alloc.get("node"):
            continue
        lines += [
            f"Host {alloc_alias(alloc)}",
            f"    HostName {alloc['node']}",
            f"    User {netid}",
            *id_lines,
            f"    ProxyJump {login_alias(alloc['cluster'])}",
            "    ControlMaster auto",
            "    ControlPath ~/.ssh/hpc-alloc-%C",
            "    ControlPersist 4h",
            "    StrictHostKeyChecking accept-new",
            f"    UserKnownHostsFile {KNOWN_HOSTS}",
            "    ServerAliveInterval 15",
            "    ServerAliveCountMax 3",
            "",
        ]
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    SSH_CONFIG.write_text("\n".join(lines))
    SSH_CONFIG.chmod(0o600)


def ensure_include():
    """Make ~/.ssh/config Include our managed file (prepended, once)."""
    SSH_DIR.mkdir(mode=0o700, exist_ok=True)
    existing = USER_SSH_CONFIG.read_text() if USER_SSH_CONFIG.exists() else ""
    if INCLUDE_LINE in existing:
        return
    header = f"# hpc-alloc managed hosts\n{INCLUDE_LINE}\n\n"
    USER_SSH_CONFIG.write_text(header + existing)
    USER_SSH_CONFIG.chmod(0o600)
    info(f"added '{INCLUDE_LINE}' to {USER_SSH_CONFIG}")


# ------------------------------------------------------------- ssh plumbing

_verified = set()  # clusters whose login connection was probed OK this run
_last_probe = None  # result of the most recent fresh probe ('ok'|'auth'|'net')


def can_prompt():
    """Whether interactive auth (Duo) can reach the user. ssh prompts via
    /dev/tty, not stdin — so a shell with piped stdin but a controlling
    terminal (e.g. Claude Code's `!` commands) can still authenticate."""
    if sys.stdin.isatty():
        return True
    try:
        fd = os.open("/dev/tty", os.O_RDWR)
        os.close(fd)
        return True
    except OSError:
        return False


def master_alive(cluster):
    r = subprocess.run(
        ["ssh", "-O", "check", "--", login_alias(cluster)],
        capture_output=True, text=True,
    )
    return r.returncode == 0


def close_master(alias):
    """Tear down a multiplexed master connection for an alias, if one exists."""
    subprocess.run(["ssh", "-O", "exit", "--", alias], capture_output=True, text=True)


def forget_hostkey(node):
    """Drop a node's host key: compute nodes get reimaged, and a stale key turns
    the next allocation on that node into a scary hard MITM failure."""
    if KNOWN_HOSTS.exists():
        subprocess.run(["ssh-keygen", "-R", node, "-f", str(KNOWN_HOSTS)],
                       capture_output=True, text=True)


def sweep_dead_sockets():
    """Remove control sockets whose master died (e.g. during sleep). A dead
    socket file makes OpenSSH silently disable multiplexing — Duo on every
    command — so these must be cleaned, and `-O exit` can't do it."""
    for sock in SSH_DIR.glob("hpc-alloc-*"):
        r = subprocess.run(["ssh", "-S", str(sock), "-O", "check", "unused"],
                           capture_output=True, text=True)
        if r.returncode != 0:
            try:
                sock.unlink()
            except OSError:
                pass


def heal_connections(state, cluster):
    """Close all masters for a cluster (compute nodes first, then login) and
    sweep orphaned socket files."""
    for alloc in state.get("allocs", {}).values():
        if alloc["cluster"] == cluster and alloc.get("node"):
            close_master(alloc_alias(alloc))
    close_master(login_alias(cluster))
    sweep_dead_sockets()
    _verified.discard(cluster)


def probe(alias, timeout=15):
    """Test real end-to-end reachability (a live-looking master can be dead).

    Returns 'ok', 'auth' (host reachable but needs interactive auth, i.e. Duo),
    or 'net' (unresolvable/unreachable/stalled)."""
    try:
        r = subprocess.run(
            ["ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=10", "--", alias, "true"],
            capture_output=True, text=True, timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return "net"
    if r.returncode == 0:
        return "ok"
    s = (r.stderr or "").lower()
    if "permission denied" in s or "authentication" in s:
        return "auth"
    return "net"


def try_login(cluster, interactive=None):
    """Establish/verify the login master. Returns bool; never exits."""
    global _last_probe
    if cluster in _verified:
        return True
    if interactive is None:
        interactive = can_prompt()
    alias = login_alias(cluster)
    if master_alive(cluster):
        if probe(alias) == "ok":
            _verified.add(cluster)
            return True
        info(f"connection to {alias} is stale (VPN drop or sleep?) — resetting")
        heal_connections(load_state(), cluster)
    st = probe(alias)  # fresh attempt; succeeds if no interactive auth needed
    _last_probe = st
    if st == "ok":
        _verified.add(cluster)
        return True
    if st == "auth" and interactive:
        info(f"connecting to {alias} (answer the Duo prompt in your terminal)...")
        r = subprocess.run(["ssh", "-o", "ConnectTimeout=30", "--", alias, "true"])
        if r.returncode == 0:
            _verified.add(cluster)
            return True
    return False


def ensure_login(cluster):
    if try_login(cluster):
        return
    if _last_probe == "auth":
        if not can_prompt():
            die(f"{login_alias(cluster)} is reachable but needs interactive (Duo) auth.\n"
                "  Run `hpc-alloc connect` in a terminal, then retry.", code=EXIT_CONNLOST)
        die("authentication failed. Check that:\n"
            f"  - the right public key is uploaded at {KEY_UPLOADER} "
            f"(pinned: {cfg('ssh', 'identity_file') or 'none — ssh default order'})\n"
            "  - the Duo prompt was approved\n"
            "  - the NetID is correct (see `hpc-alloc config` and the managed ssh_config)",
            code=EXIT_CONNLOST)
    die(f"cannot reach {login_alias(cluster)} — is the Yale VPN connected?\n"
        "  (verify host/NetID via `hpc-alloc config` and ~/.config/hpc-alloc/ssh_config)",
        code=EXIT_CONNLOST)


def login_run(cluster, remote_cmd, check=True, timeout=60, _retry=True):
    """Run a command on the login node over the multiplexed connection.

    Raises ConnectionLost on transport failure/stall (after one heal+retry)."""
    ensure_login(cluster)
    try:
        r = subprocess.run(
            ["ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=20", "--",
             login_alias(cluster), remote_cmd],
            capture_output=True, text=True, timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        r = None
    if r is None or r.returncode == 255:  # 255 = ssh transport error
        _verified.discard(cluster)
        if _retry and try_login(cluster):
            return login_run(cluster, remote_cmd, check=check, timeout=timeout, _retry=False)
        detail = "command stalled" if r is None else (r.stderr.strip() or "ssh failed")
        raise ConnectionLost(detail)
    if check and r.returncode != 0:
        die(f"remote command failed on {login_alias(cluster)}: {remote_cmd}\n{r.stderr.strip()}")
    return r


def wait_reconnect(cluster, budget=600):
    """Patiently re-probe after a drop (interactive use). True once reconnected."""
    info(f"retrying for up to {budget // 60} minutes — Ctrl-C is safe, jobs stay queued")
    deadline = time.monotonic() + budget
    while time.monotonic() < deadline:
        time.sleep(15)
        if try_login(cluster):
            info("reconnected")
            return True
    return False


# ------------------------------------------------------------- slurm helpers

def squeue_all(cluster):
    """All of the user's queued/running jobs:
    {jobid: (state, node, reason, time_left, partition, jobname)}.
    Raises ConnectionLost if the queue could not actually be queried — absence
    of a job is only meaningful when this returns normally."""
    r = login_run(cluster, "squeue --me -h -o '%i|%T|%N|%r|%L|%P|%j'", check=False)
    if r.returncode != 0:
        raise ConnectionLost(f"squeue failed: {r.stderr.strip() or 'unknown error'}")
    out = {}
    for line in r.stdout.strip().splitlines():
        parts = line.strip().split("|")
        if len(parts) == 7:
            out[parts[0]] = tuple(parts[1:])
    return out


def squeue_query(cluster, jobids):
    """Subset of squeue_all for specific ids, without the jobname field."""
    q = squeue_all(cluster)
    return {j: q[j][:5] for j in jobids if j in q}


def remote_home(cluster, state):
    """The user's home directory on the cluster (cached in state)."""
    cfg = state["clusters"][cluster]
    if not cfg.get("home"):
        r = login_run(cluster, 'printf "%s" "$HOME"')
        home = r.stdout.strip()
        cfg["home"] = home
        with locked_state() as st:
            st["clusters"].setdefault(cluster, {"host": cfg["host"]})["home"] = home
    return cfg["home"]


def gpu_util(alias, timeout=15):
    """Max GPU utilization % on a node, or None if unqueryable."""
    try:
        r = subprocess.run(
            ["ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=10", "--", alias,
             "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return None
    if r.returncode != 0:
        return None
    vals = [int(x) for x in r.stdout.split() if x.strip().isdigit()]
    return max(vals) if vals else None


def timeleft_minutes(s):
    """Parse squeue %L ([D-]HH:MM:SS, MM:SS, or minutes) to minutes, else None."""
    if not s or not s[0].isdigit():
        return None
    days = 0
    if "-" in s:
        d, s = s.split("-", 1)
        days = int(d)
    try:
        parts = [int(x) for x in s.split(":")]
    except ValueError:
        return None
    if len(parts) == 3:
        h, m, _sec = parts
    elif len(parts) == 2:
        h, (m, _sec) = 0, parts
    elif len(parts) == 1:
        h, m = 0, parts[0]
    else:
        return None
    return days * 1440 + h * 60 + m


def parse_gres(s):
    """'gpu:h200:8(S:0-1),gpu:2' -> [('h200', 8), ('gpu', 2)]."""
    return [(typ or "gpu", int(n))
            for typ, n in re.findall(r"gpu:(?:([^:,()\s]+):)?(\d+)", s or "")]


def classify_node_state(s):
    s = s.rstrip("*~#%!$@+^-").lower()
    if s.startswith("idle"):
        return "idle"
    if s.startswith("mix"):
        return "mix"
    if s.startswith(("alloc", "comp")):
        return "alloc"
    return "other"  # drain, down, maint, resv, ...


# ------------------------------------------------------------- subcommands

def cmd_setup(args):
    global CONFIG
    prelim = load_state()
    netid = args.netid or prelim.get("netid")
    if not netid and sys.stdin.isatty():
        netid = input("Yale NetID: ").strip()
    if not netid:
        die("NetID required: hpc-alloc setup --netid YOUR_NETID")
    cluster = args.cluster
    host = args.host or cfg("cluster", cluster, "host") or f"{cluster}.ycrc.yale.edu"

    # SSH key: reuse an existing default key, otherwise generate ed25519.
    pubkey = None
    for cand in ["id_ed25519.pub", "id_rsa.pub", "id_ecdsa.pub"]:
        p = SSH_DIR / cand
        if p.exists():
            pubkey = p
            break
    if pubkey is None:
        keyfile = SSH_DIR / "id_ed25519"
        info("no SSH key found — generating one")
        SSH_DIR.mkdir(mode=0o700, exist_ok=True)
        genargs = ["ssh-keygen", "-t", "ed25519", "-f", str(keyfile)]
        if not sys.stdin.isatty():
            genargs += ["-N", ""]
        subprocess.run(genargs, check=True)
        pubkey = keyfile.with_suffix(".pub")

    if not CONFIG_TOML.exists():
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        keypath = str(pubkey)[: -len(".pub")]
        home = str(Path.home())
        if keypath.startswith(home + "/"):
            keypath = "~" + keypath[len(home):]
        CONFIG_TOML.write_text(CONFIG_TEMPLATE.format(identity_file=keypath))
        CONFIG = load_config()  # so this run's ssh_config already pins the key
        info(f"wrote {CONFIG_TOML} (defaults + pinned SSH key; edit to taste)")

    with locked_state() as state:
        state["netid"] = netid
        existing = state.setdefault("clusters", {}).get(cluster, {})
        state["clusters"][cluster] = {**existing, "host": host}
    ensure_include()
    info(f"configured cluster '{cluster}' ({host}) for NetID '{netid}'")
    print()
    print("Your SSH public key:")
    print("  " + pubkey.read_text().strip())
    print()
    print("Next steps:")
    print(f"  1. If not done already, upload the key at {KEY_UPLOADER}")
    print("     (requires campus network or Yale VPN; allow a few minutes to propagate)")
    print(f"  2. Test the connection:   hpc-alloc connect")
    print(f"  3. Allocate a node:       hpc-alloc up --partition day --cpus 4 --time 8:00:00")


def sleeper_command(idle_minutes):
    """The sleeper job body. With idle_minutes set, self-release once every GPU
    has been <=5% utilized for that many consecutive minutes (checked per minute);
    if nvidia-smi is unavailable/failing, count the node as active, never idle."""
    if not idle_minutes:
        return "sleep infinity"
    return (
        f'echo "hpc-alloc: self-releases after {idle_minutes} min of GPU idleness"; idle=0; '
        "while true; do sleep 60; "
        'u=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null '
        "| sort -rn | head -n1); "
        'if [ "${u:-100}" -gt 5 ]; then idle=0; else idle=$((idle+1)); fi; '
        f'if [ "$idle" -ge {idle_minutes} ]; then echo "hpc-alloc: GPU idle timeout, releasing"; exit 0; fi; '
        "done"
    )


def resource_args(args, jobname, logfile):
    out = [
        "sbatch", "--parsable",
        f"--job-name={jobname}",
        f"--time={args.time}",
        "--nodes=1", "--ntasks=1",
        f"--cpus-per-task={args.cpus}",
        "--output", logfile,
    ]
    if args.mem:
        out.append(f"--mem={args.mem}")
    if args.gpus:
        out.append(f"--gpus={args.gpus}")
    if args.constraint:
        out.append(f"--constraint={args.constraint}")
    return out


def submit_prefix():
    """Ensure the remote log dir exists and prune logs older than 30 days."""
    return (f"mkdir -p {REMOTE_LOG_DIR} && "
            f"(find {REMOTE_LOG_DIR} -name '*.log' -mtime +30 -delete 2>/dev/null || true) && ")


def pick_partition(args):
    if args.partition:
        return args.partition
    ccfg = cfg("cluster", args.cluster, default={})
    if args.gpus:
        part = ccfg.get("gpu_partition") or cfg("defaults", "gpu_partition") or DEFAULT_GPU_PARTITION
        info(f"--gpus given without --partition; using '{part}'")
        return part
    return ccfg.get("partition") or cfg("defaults", "partition") or DEFAULT_PARTITION


def cmd_up(args):
    name = args.name
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9_-]*", name) or name == "login":
        die(f"invalid allocation name '{name}'")
    partition = pick_partition(args)

    idle = args.idle_timeout
    if args.gpus:
        if idle is None:
            idle = cfg_int(cfg("defaults", "idle_timeout"), "defaults.idle_timeout")
            if idle is None:
                idle = DEFAULT_GPU_IDLE_MINUTES
        if idle == 0:
            idle = None
    elif idle:
        info("--idle-timeout only applies to GPU allocations (it watches nvidia-smi); ignoring")
        idle = None

    sbatch = resource_args(args, f"{JOB_PREFIX}{name}", f"{REMOTE_LOG_DIR}/%j.log")
    sbatch += [f"--partition={partition}", "--wrap", sleeper_command(idle)]
    remote_cmd = submit_prefix() + " ".join(shlex.quote(a) for a in sbatch)
    if args.dry_run:
        print(remote_cmd)
        return

    state = load_state()
    require_setup(state)
    cluster = args.cluster
    if cluster not in state["clusters"]:
        die(f"cluster '{cluster}' not configured; run: hpc-alloc setup --cluster {cluster}")

    existing = state["allocs"].get(name)
    if existing:
        live = squeue_query(existing["cluster"], [existing["jobid"]])
        q = live.get(existing["jobid"])
        if q and q[0] not in ENDED_STATES:
            die(f"allocation '{name}' already exists (job {existing['jobid']}, {q[0]}). "
                f"Use --name for a second one, or `hpc-alloc down {name}`.")

    r = login_run(cluster, remote_cmd)
    jobid = r.stdout.strip().split(";")[0]
    if not jobid.isdigit():
        die(f"unexpected sbatch output: {r.stdout.strip()}")
    alloc = {
        "name": name, "cluster": cluster, "jobid": jobid, "node": None,
        "partition": partition, "time": args.time, "gpus": args.gpus,
        "idle_timeout": idle,
        "created": time.strftime("%Y-%m-%d %H:%M:%S"),
    }
    with locked_state() as st:
        st["allocs"][name] = alloc
    extra = f", self-releases after {idle} idle GPU minutes" if idle else ""
    info(f"submitted job {jobid} on {cluster} (partition {partition}, {args.time}{extra})")

    if args.no_wait:
        info(f"not waiting; run `hpc-alloc status` later to finish SSH setup once it starts")
        return
    wait_for_running(alloc, args.wait_timeout)


def wait_for_running(alloc, timeout):
    name, cluster, jobid = alloc["name"], alloc["cluster"], alloc["jobid"]
    start = time.monotonic()
    printed_estimate = False
    try:
        while True:
            try:
                live = squeue_query(cluster, [jobid])
            except ConnectionLost as e:
                info(f"connection lost while waiting ({e}) — job {jobid} stays queued regardless")
                if not can_prompt():
                    die("reconnect (VPN, then `hpc-alloc connect`), then run `hpc-alloc status` "
                        "to finish SSH setup", code=EXIT_CONNLOST)
                if not wait_reconnect(cluster):
                    die(f"could not reconnect. Job {jobid} remains queued; run `hpc-alloc status` "
                        "once back online.", code=EXIT_CONNLOST)
                continue
            q = live.get(jobid)
            if q and q[0] in ENDED_STATES:
                q = None
            if q is None:
                try:
                    r = login_run(cluster, f"sacct -j {jobid} -X -n -o State%20,ExitCode", check=False)
                    final = r.stdout.strip() or "unknown (left the queue)"
                except ConnectionLost:
                    final = "unknown"
                with locked_state() as st:
                    st["allocs"].pop(name, None)
                die(f"job {jobid} ended before starting: {final}\n"
                    f"log (on the cluster): ~/{REMOTE_LOG_DIR}/{jobid}.log\n"
                    f"diagnose with: hpc-alloc why {jobid}")
            st_, node, reason, time_left, _part = q
            if st_ == "RUNNING":
                forget_hostkey(node)
                with locked_state() as st:
                    if name in st["allocs"]:
                        st["allocs"][name]["node"] = node
                alloc["node"] = node
                finish_alloc(alloc, time_left)
                return
            elapsed = int(time.monotonic() - start)
            info(f"job {jobid}: {st_} (reason: {reason}, waited {elapsed}s)")
            if elapsed > 30 and not printed_estimate:
                r = login_run(cluster, f"squeue -j {jobid} --start -h -o '%S'", check=False)
                est = r.stdout.strip()
                if est and est != "N/A":
                    info(f"scheduler's estimated start time: {est}")
                printed_estimate = True
            if elapsed > timeout:
                info(f"still pending after {timeout}s — leaving job in queue.")
                info(f"check later with `hpc-alloc status`, diagnose with `hpc-alloc why {name}`, "
                     f"or cancel with `hpc-alloc down {name}`")
                return
            time.sleep(5)
    except KeyboardInterrupt:
        print()
        info(f"interrupted — job {jobid} is still in the queue.")
        info(f"`hpc-alloc status` to check on it, `hpc-alloc down {name}` to cancel.")
        sys.exit(130)


def finish_alloc(alloc, time_left=None):
    """Node is known: verify SSH reachability and print connection info."""
    name = alloc["name"]
    alias = alloc_alias(alloc)
    for attempt in range(5):
        r = subprocess.run(
            ["ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=15", "--", alias, "true"],
            capture_output=True, text=True,
        )
        if r.returncode == 0:
            break
        time.sleep(3)
    else:
        info(f"warning: node {alloc['node']} allocated but SSH check failed:\n{r.stderr.strip()}")
    print()
    info(f"allocation '{name}' ready: node {alloc['node']} (job {alloc['jobid']}"
         + (f", {time_left} left" if time_left else "") + ")")
    idle_note = ""
    if alloc.get("idle_timeout"):
        idle_note = (f"\n  Idle policy:  self-releases after {alloc['idle_timeout']} min of GPU"
                     " idleness (YCRC also cancels idle-GPU jobs)")
    print(f"""
  Shell:        ssh {alias}          (or: hpc-alloc ssh {name})
  Run command:  hpc-alloc ssh {name} -- nvidia-smi
  Sync code:    hpc-alloc sync {name} ./myproject '~/myproject'
  VS Code:      connect Remote-SSH to host '{alias}'
  Claude Code:  ssh {alias} then run `claude` in your project directory{idle_note}

  The node goes away when the job hits its time limit or you run `hpc-alloc down {name}`.""")


def refresh_status(state):
    """Reconcile allocations with the queue and discover `run` jobs.

    Returns (rows, runs): rows = [(alloc, state_str, time_left)], runs = [dict].
    Raises ConnectionLost (without touching state) if a queue can't be queried."""
    queues = {c: squeue_all(c) for c in state.get("clusters", {})}
    runs = []
    for cluster, q in queues.items():
        for jid, (st_, node, _reason, left, part, jname) in sorted(q.items()):
            if jname.startswith(JOB_PREFIX + "run"):
                runs.append({"jobid": jid, "cluster": cluster, "state": st_,
                             "node": node or None, "partition": part, "time_left": left,
                             "log": f"~/{REMOTE_LOG_DIR}/run-{jid}.log"})
    rows = []
    with locked_state() as st:
        for name, alloc in sorted(list(st["allocs"].items())):
            q = queues.get(alloc["cluster"], {}).get(alloc["jobid"])
            if q is None or q[0] in ENDED_STATES:
                if alloc.get("node"):
                    close_master(alloc_alias(alloc))
                    forget_hostkey(alloc["node"])
                rows.append((alloc, "ENDED", ""))
                del st["allocs"][name]
                continue
            st_, node, reason, time_left, _part, _name = q
            if st_ == "RUNNING" and not alloc.get("node"):
                forget_hostkey(node)
                alloc["node"] = node
            rows.append((alloc, st_ if st_ == "RUNNING" else f"{st_} ({reason})", time_left))
    return rows, runs


def expiring(state_str, time_left):
    mins = timeleft_minutes(time_left)
    return state_str == "RUNNING" and mins is not None and mins <= EXPIRY_WARN_MINUTES


def cmd_status(args):
    state = load_state()
    require_setup(state)
    rows, runs = refresh_status(state)
    utils = {}
    for alloc, st_, _tl in rows:
        if st_ == "RUNNING" and alloc.get("gpus") and alloc.get("node"):
            utils[alloc["name"]] = gpu_util(alloc_alias(alloc))
    if args.json:
        payload = [
            {**alloc, "state": st_, "time_left": tl,
             "gpu_util": utils.get(alloc["name"]),
             "expiring_soon": expiring(st_, tl),
             "alias": alloc_alias(alloc) if alloc.get("node") else None}
            for alloc, st_, tl in rows
        ]
        print(json.dumps({"allocs": payload, "runs": runs}, indent=2))
        return
    if not rows and not runs:
        info("no active allocations or run jobs")
        return
    if rows:
        fmt = "{:<12} {:<9} {:<22} {:<12} {:<14} {:<11} {:<5} {}"
        print(fmt.format("NAME", "JOB", "STATE", "PARTITION", "NODE", "LEFT", "GPU", "SSH ALIAS"))
        for alloc, st_, tl in rows:
            u = utils.get(alloc["name"])
            left = (tl or "-") + ("!" if expiring(st_, tl) else "")
            print(fmt.format(alloc["name"], alloc["jobid"], st_, alloc["partition"],
                             alloc.get("node") or "-", left,
                             f"{u}%" if u is not None else "-",
                             alloc_alias(alloc) if alloc.get("node") else "-"))
    if runs:
        print()
        fmt = "{:<9} {:<12} {:<12} {:<14} {:<11} {}"
        print(fmt.format("RUN JOB", "STATE", "PARTITION", "NODE", "LEFT", "FOLLOW"))
        for rj in runs:
            print(fmt.format(rj["jobid"], rj["state"], rj["partition"], rj["node"] or "-",
                             rj["time_left"] or "-", f"hpc-alloc logs {rj['jobid']} -f"))


def pick_alloc(state, name):
    allocs = state["allocs"]
    if name:
        if name not in allocs:
            die(f"no allocation named '{name}' (see `hpc-alloc status`)")
        return allocs[name]
    if len(allocs) == 1:
        return next(iter(allocs.values()))
    if "dev" in allocs:
        return allocs["dev"]
    die("multiple allocations exist — specify a name (see `hpc-alloc status`)")


def check_node_reachable(state, alloc):
    """Probe the compute node, healing a stale node master once. Dies with a
    useful message (expired allocation vs connection trouble) if unreachable."""
    alias = alloc_alias(alloc)
    st = probe(alias)
    if st != "ok":
        close_master(alias)
        st = probe(alias)
    if st == "ok":
        return
    try:
        live = squeue_query(alloc["cluster"], [alloc["jobid"]])
        q = live.get(alloc["jobid"])
        if q is None or q[0] in ENDED_STATES:
            die(f"allocation '{alloc['name']}' has ended (walltime expiry, scancel, or the "
                "idle-GPU policy — `hpc-alloc why " + alloc["jobid"] + "` to find out). "
                "Run `hpc-alloc status` to clean up, then `hpc-alloc up` again.")
    except ConnectionLost:
        pass
    die(f"cannot reach node {alloc['node']} — run `hpc-alloc connect` in a terminal, then retry.",
        code=EXIT_CONNLOST)


def split_ssh_args(state, tokens):
    """`hpc-alloc ssh [NAME] [-- CMD...]`: first token is a name only if it
    matches an existing allocation; everything else is the remote command."""
    if tokens and tokens[0] == "--":
        tokens = tokens[1:]
    name = None
    if tokens and tokens[0] in state["allocs"]:
        name, tokens = tokens[0], tokens[1:]
    if tokens and tokens[0] == "--":
        tokens = tokens[1:]
    return name, tokens


def cmd_ssh(args):
    state = load_state()
    require_setup(state)
    name, command = split_ssh_args(state, args.args)
    alloc = pick_alloc(state, name)
    if not alloc.get("node"):
        die(f"allocation '{alloc['name']}' has no node yet (job {alloc['jobid']} still pending?) "
            "— run `hpc-alloc status`")
    ensure_login(alloc["cluster"])
    check_node_reachable(state, alloc)
    alias = alloc_alias(alloc)
    if command:
        # Space-join like ssh itself: the remote shell interprets the result,
        # so `hpc-alloc ssh dev -- 'cd proj && make'` works as written.
        os.execvp("ssh", ["ssh", "-o", "BatchMode=yes", "--", alias, " ".join(command)])
    os.execvp("ssh", ["ssh", "--", alias])


def cmd_sync(args):
    state = load_state()
    require_setup(state)
    alloc = pick_alloc(state, args.name)
    if not alloc.get("node"):
        die(f"allocation '{alloc['name']}' has no node yet — run `hpc-alloc status`")
    ensure_login(alloc["cluster"])
    check_node_reachable(state, alloc)
    alias = alloc_alias(alloc)
    src, dst = args.src, args.dst
    if args.pull:
        src, dst = f"{alias}:{src}", dst
    else:
        src, dst = src, f"{alias}:{dst}"
    rsync = ["rsync", "-az", "-e", "ssh"]  # no --info/--stats: macOS ships openrsync
    if args.delete:
        rsync.append("--delete")
    rsync += [src, dst]
    info(" ".join(rsync))
    sys.exit(subprocess.run(rsync).returncode)


def cmd_run(args):
    """Run a command as a short-lived batch job: resources are only held while
    the command executes — the GPU-idle-friendly way to use GPU partitions."""
    command = args.command
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        die("no command given — usage: hpc-alloc run [options] -- CMD ...")
    partition = pick_partition(args)
    cluster = args.cluster

    if args.dry_run:
        logfile = "$HOME/.hpc-alloc/run-%j.log"
    else:
        state = load_state()
        require_setup(state)
        if cluster not in state["clusters"]:
            die(f"cluster '{cluster}' not configured; run: hpc-alloc setup --cluster {cluster}")
        home = remote_home(cluster, state)
        logfile = f"{home}/{REMOTE_LOG_DIR}/run-%j.log"
        if args.chdir and args.chdir.startswith("~"):  # Slurm --chdir doesn't expand ~
            rest = args.chdir[1:].lstrip("/")
            args.chdir = f"{home}/{rest}" if rest else home

    sbatch = resource_args(args, f"{JOB_PREFIX}run", logfile)
    sbatch.append(f"--partition={partition}")
    if args.chdir:
        sbatch.append(f"--chdir={args.chdir}")
    sbatch += ["--wrap", " ".join(command)]
    remote_cmd = submit_prefix() + " ".join(shlex.quote(a) for a in sbatch)
    if args.dry_run:
        print(remote_cmd)
        return

    r = login_run(cluster, remote_cmd)
    jobid = r.stdout.strip().split(";")[0]
    if not jobid.isdigit():
        die(f"unexpected sbatch output: {r.stdout.strip()}")
    logpath = f"{REMOTE_LOG_DIR}/run-{jobid}.log"
    if args.detach:
        info(f"submitted run job {jobid} on {partition} ({args.time} limit, log: ~/{logpath})")
        info(f"follow with `hpc-alloc logs {jobid} -f`, cancel with `hpc-alloc cancel {jobid}`")
        return
    info(f"submitted run job {jobid} on {partition} ({args.time} limit, log: ~/{logpath}); "
         "Ctrl-C cancels it")
    stream_job(cluster, jobid, logpath)


def stream_job(cluster, jobid, logpath):
    """Follow a batch job: show queue progress, stream its log, mirror its exit code."""
    offset = 0
    last_note = 0.0
    try:
        while True:
            try:
                live = squeue_query(cluster, [jobid])
            except ConnectionLost as e:
                info(f"connection lost ({e}) — job {jobid} keeps running; log: ~/{logpath}")
                if not can_prompt():
                    die(f"reconnect, then reattach with `hpc-alloc logs {jobid} -f`",
                        code=EXIT_CONNLOST)
                if not wait_reconnect(cluster):
                    die(f"could not reconnect; job {jobid} continues — reattach with "
                        f"`hpc-alloc logs {jobid} -f`", code=EXIT_CONNLOST)
                continue
            q = live.get(jobid)
            if q and q[0] == "PENDING":
                if time.monotonic() - last_note > 30:
                    info(f"job {jobid}: PENDING (reason: {q[2]})")
                    last_note = time.monotonic()
                time.sleep(5)
                continue
            r = login_run(cluster, f"tail -c +{offset + 1} {shlex.quote(logpath)} 2>/dev/null || true",
                          check=False)
            if r.stdout:
                sys.stdout.write(r.stdout)
                sys.stdout.flush()
                offset += len(r.stdout.encode())
            if q is None or q[0] in ENDED_STATES:
                break
            time.sleep(3)
    except KeyboardInterrupt:
        print()
        info(f"cancelling job {jobid}")
        try:
            login_run(cluster, f"scancel {jobid}", check=False)
        except ConnectionLost:
            info(f"could not cancel (connection lost) — run `hpc-alloc cancel {jobid}` later")
        sys.exit(130)
    code = 0
    try:
        r = login_run(cluster, f"sacct -j {jobid} -X -n -o State,ExitCode", check=False)
        fields = r.stdout.split()
        if len(fields) >= 2:
            jstate, exitcode = fields[0], fields[1]
            code = int(exitcode.split(":")[0]) if ":" in exitcode else 0
            if jstate.startswith("CANCELLED") or jstate == "TIMEOUT":
                code = code or 1
            info(f"job {jobid} finished: {jstate} (exit {code})")
    except ConnectionLost:
        info(f"job {jobid} left the queue; could not fetch its final state")
    sys.exit(code)


def cmd_logs(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    target = args.target
    if target in state["allocs"]:
        alloc = state["allocs"][target]
        cluster, jobid = alloc["cluster"], alloc["jobid"]
        logpath = f"{REMOTE_LOG_DIR}/{jobid}.log"
    elif target.isdigit():
        jobid = target
        r = login_run(cluster,
                      f'for f in {REMOTE_LOG_DIR}/run-{jobid}.log {REMOTE_LOG_DIR}/{jobid}.log; '
                      'do [ -f "$f" ] && echo "$f" && break; done', check=False)
        logpath = r.stdout.strip() or f"{REMOTE_LOG_DIR}/run-{jobid}.log"
    else:
        die(f"'{target}' is neither an allocation name nor a job id")
    if args.follow:
        stream_job(cluster, jobid, logpath)
        return
    r = login_run(cluster, f"tail -n {args.lines} {shlex.quote(logpath)}", check=False)
    if r.returncode != 0:
        die(f"no log at ~/{logpath} on {cluster}: {r.stderr.strip()}")
    sys.stdout.write(r.stdout)


def cmd_cancel(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    jobid = args.jobid
    if not jobid.isdigit():
        die(f"'{jobid}' is not a job id (for named allocations use `hpc-alloc down NAME`)")
    q = squeue_all(cluster).get(jobid)
    if q is None:
        r = login_run(cluster, f"sacct -j {jobid} -X -n -P -o JobName", check=False)
        jname = (r.stdout.strip().splitlines() or [""])[0]
        if jname.startswith(JOB_PREFIX):
            info(f"job {jobid} has already finished")
            return
        die(f"job {jobid} not found among your jobs")
    if not q[5].startswith(JOB_PREFIX):
        die(f"refusing: job {jobid} ('{q[5]}') was not created by hpc-alloc")
    login_run(cluster, f"scancel {jobid}", check=False)
    with locked_state() as st:
        for n, a in list(st["allocs"].items()):
            if a["jobid"] == jobid and a["cluster"] == cluster:
                if a.get("node"):
                    close_master(alloc_alias(a))
                del st["allocs"][n]
    info(f"cancelled job {jobid}")


def cmd_down(args):
    state = load_state()
    require_setup(state)
    names = list(state["allocs"]) if args.all else [args.name or pick_alloc(state, None)["name"]]
    if not names:
        info("no active allocations")
        return
    for name in names:
        alloc = state["allocs"].get(name)
        if not alloc:
            info(f"no allocation named '{name}'")
            continue
        login_run(alloc["cluster"], f"scancel {alloc['jobid']}", check=False)
        if alloc.get("node"):
            close_master(alloc_alias(alloc))
        with locked_state() as st:
            st["allocs"].pop(name, None)
        info(f"cancelled job {alloc['jobid']} ('{name}')")


def cmd_connect(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    if args.reset:
        heal_connections(state, cluster)
        info("closed login and compute-node master connections; swept dead sockets")
    ensure_login(cluster)
    r = login_run(cluster, "hostname")
    info(f"login OK: {r.stdout.strip()} (multiplexed — no Duo again for ~4h of idle)")
    for name, alloc in sorted(state["allocs"].items()):
        if alloc["cluster"] != cluster or not alloc.get("node"):
            continue
        alias = alloc_alias(alloc)
        st = probe(alias)
        if st != "ok":
            close_master(alias)
            st = probe(alias)
        if st == "ok":
            info(f"node {alloc['node']} ('{name}'): OK")
        else:
            info(f"node {alloc['node']} ('{name}'): unreachable — allocation may have ended; "
                 "run `hpc-alloc status`")


def cmd_partitions(args):
    state = load_state()
    require_setup(state)
    r = login_run(args.cluster, "sinfo -o '%P|%a|%l|%D|%c|%m|%G|%f'")
    rows = [l.split("|") for l in r.stdout.strip().splitlines()]
    if args.json:
        keys = ["partition", "avail", "timelimit", "nodes", "cpus", "memory", "gres", "features"]
        print(json.dumps([dict(zip(keys, row)) for row in rows[1:] if len(row) == len(keys)],
                         indent=2))
        return
    widths = [max(len(row[i]) for row in rows) for i in range(len(rows[0]))]
    for row in rows:
        print("  ".join(cell.ljust(w) for cell, w in zip(row, widths)))


def cmd_avail(args):
    """Digest of free capacity: idle CPUs and free GPUs by type, per partition."""
    state = load_state()
    require_setup(state)
    fmt = "Partition:30,StateCompact:12,NodeHost:30,Gres:60,GresUsed:60,CPUsState:30"
    r = login_run(args.cluster, f"sinfo -h -N -O '{fmt}'")
    parts = {}
    for line in r.stdout.splitlines():
        f = line.split()
        if len(f) < 6:
            continue
        pname, nstate, _node, gres, gresused, cpus = f[0].rstrip("*"), f[1], f[2], f[3], f[4], f[5]
        if args.partition and pname != args.partition:
            continue
        p = parts.setdefault(pname, {"nodes": {"idle": 0, "mix": 0, "alloc": 0, "other": 0},
                                     "cpus_idle": 0, "cpus_total": 0, "gpus": {}})
        cls = classify_node_state(nstate)
        p["nodes"][cls] += 1
        if cls == "other":  # drained/down/maint nodes don't contribute capacity
            continue
        try:
            _a, i, _o, t = (int(x) for x in cpus.split("/"))
        except ValueError:
            i = t = 0
        p["cpus_idle"] += i
        p["cpus_total"] += t
        for typ, n in parse_gres(gres):
            p["gpus"].setdefault(typ, {"total": 0, "used": 0})["total"] += n
        for typ, n in parse_gres(gresused):
            p["gpus"].setdefault(typ, {"total": 0, "used": 0})["used"] += n
    for p in parts.values():
        for g in p["gpus"].values():
            g["free"] = g["total"] - g["used"]
    if args.json:
        print(json.dumps({"partitions": parts}, indent=2))
        return
    if not parts:
        info("no matching partitions")
        return
    fmt = "{:<14} {:<22} {:<16} {}"
    print(fmt.format("PARTITION", "NODES idle/mix/alloc/off", "CPUS free/total", "GPUS free/total"))
    for pname, p in sorted(parts.items()):
        n = p["nodes"]
        gpus = "  ".join(f"{t} {g['free']}/{g['total']}" for t, g in sorted(p["gpus"].items())) or "-"
        print(fmt.format(pname, f"{n['idle']}/{n['mix']}/{n['alloc']}/{n['other']}",
                         f"{p['cpus_idle']}/{p['cpus_total']}", gpus))


def cmd_config(args):
    """Show effective defaults (config.toml merged over built-ins). No network."""
    builtins = {
        "cluster": DEFAULT_CLUSTER, "partition": DEFAULT_PARTITION,
        "gpu_partition": DEFAULT_GPU_PARTITION, "time": DEFAULT_TIME,
        "cpus": DEFAULT_CPUS, "mem": None, "idle_timeout": DEFAULT_GPU_IDLE_MINUTES,
    }
    defaults = {}
    for key, builtin in builtins.items():
        v = cfg("defaults", key)
        defaults[key] = {"value": v if v is not None else builtin,
                         "source": "config" if v is not None else "builtin"}
    ident = cfg("ssh", "identity_file")
    out = {
        "config_file": str(CONFIG_TOML),
        "config_exists": CONFIG_TOML.exists(),
        "defaults": defaults,
        "ssh_identity_file": ident,
        "cluster_overrides": cfg("cluster", default={}),
    }
    if args.json:
        print(json.dumps(out, indent=2))
        return
    info(f"config file: {CONFIG_TOML}"
         + ("" if out["config_exists"] else " (absent — all values are built-ins)"))
    for key, d in defaults.items():
        val = d["value"] if d["value"] is not None else "(Slurm default: 5120MB per CPU)"
        print(f"  {key:<15} {str(val):<28} [{d['source']}]")
    print(f"  {'identity_file':<15} "
          f"{ident or '(not pinned — ssh offers every key)':<28} "
          f"[{'config' if ident else 'builtin'}]")
    for cname, over in sorted((out["cluster_overrides"] or {}).items()):
        pairs = ", ".join(f"{k}={v}" for k, v in over.items())
        print(f"  cluster.{cname}: {pairs}")


def cmd_why(args):
    """One-shot diagnosis of a pending, running, or dead job."""
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    target = args.target
    name = None
    if target and target in state["allocs"]:
        alloc = state["allocs"][target]
        name, jobid, cluster = target, alloc["jobid"], alloc["cluster"]
    elif target and target.isdigit():
        jobid = target
    elif not target:
        alloc = pick_alloc(state, None)
        name, jobid, cluster = alloc["name"], alloc["jobid"], alloc["cluster"]
    else:
        die(f"'{target}' is neither an allocation name nor a job id")

    queue = squeue_all(cluster)
    q = queue.get(jobid)
    result = {"jobid": jobid, "name": name, "cluster": cluster}
    detail = []
    if q and q[0] not in ENDED_STATES:
        st_, node, reason, left, part, _jname = q
        result.update(status=st_, partition=part, node=node or None,
                      time_left=left, reason=reason)
        if st_ == "PENDING":
            if reason.startswith(("QOSMax", "QOSGrp", "AssocGrp", "MaxTRESPer", "QOSUsage")):
                result["diagnosis"] = (f"a per-user/group resource cap ({reason}) — this will not "
                                       "start until your other jobs release resources")
                mine = [f"{j} ({t[4]}, {t[0]}, '{t[5]}')" for j, t in sorted(queue.items())
                        if t[0] == "RUNNING"]
                detail.append("your running jobs: " + (", ".join(mine) or "none visible"))
            elif "ReqNodeNotAvail" in reason or "Reserv" in reason:
                result["diagnosis"] = ("required nodes are reserved (usually an upcoming "
                                       "maintenance window) — a shorter --time that finishes "
                                       "before the window may start immediately")
                r = login_run(cluster, "scontrol -o show reservation", check=False)
                detail += r.stdout.strip().splitlines()[:5]
            else:
                result["diagnosis"] = f"normal queue contention ({reason})"
                r = login_run(cluster, f"squeue -j {jobid} --start -h -o '%S'", check=False)
                est = r.stdout.strip()
                if est and est != "N/A":
                    detail.append(f"scheduler's estimated start: {est}")
                r = login_run(cluster, f"sprio -l -j {jobid}", check=False)
                detail += r.stdout.strip().splitlines()[:3]
        else:
            note = f"running on {node}, {left} left"
            if expiring(st_, left):
                note += " — EXPIRING SOON, sync results out"
            result["diagnosis"] = note
    else:
        result["status"] = "ended"
        r = login_run(cluster, f"sacct -j {jobid} -X -n -P -o State,ExitCode,Elapsed,Timelimit",
                      check=False)
        rec = (r.stdout.strip().splitlines() or [""])[0].split("|")
        if len(rec) >= 4 and rec[0]:
            jstate, exitcode, elapsed, limit = rec[0], rec[1], rec[2], rec[3]
            result.update(final_state=jstate, exit_code=exitcode, elapsed=elapsed)
            if jstate == "TIMEOUT":
                result["diagnosis"] = f"hit its walltime limit ({elapsed} of {limit})"
            elif jstate == "OUT_OF_MEMORY":
                result["diagnosis"] = "ran out of memory — request more with --mem"
            elif jstate.startswith("CANCELLED"):
                by = jstate.partition("by")[2].strip()
                result["diagnosis"] = (f"cancelled by uid {by} — if that isn't you, it was YCRC "
                                       "staff or the idle-GPU daemon" if by else "cancelled")
            elif jstate == "COMPLETED":
                result["diagnosis"] = ("exited normally (for a GPU allocation this can be the "
                                       "idle watchdog self-releasing — check the log)")
            else:
                result["diagnosis"] = f"{jstate} (exit {exitcode.split(':')[0]})"
            r = login_run(cluster,
                          f"tail -n 15 {REMOTE_LOG_DIR}/run-{jobid}.log "
                          f"{REMOTE_LOG_DIR}/{jobid}.log 2>/dev/null || true", check=False)
            tail = [l for l in r.stdout.strip().splitlines() if not l.startswith("==>")]
            if tail:
                detail += ["--- log tail ---"] + tail[-15:]
        else:
            result["diagnosis"] = "no accounting record found for this job id"
    result["detail"] = detail
    if args.json:
        print(json.dumps(result, indent=2))
        return
    label = f"job {jobid}" + (f" ('{name}')" if name else "")
    info(f"{label}: {result.get('status', '?')} — {result['diagnosis']}")
    for line in detail:
        print(f"  {line}")


