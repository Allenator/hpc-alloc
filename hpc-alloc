def parse_toml_subset(text):
    """Minimal TOML for this config's shape — [dotted.sections] and
    key = "string" | integer | true/false. Fallback for Python < 3.11
    (no tomllib); keep the config file to this subset if your python3 is old."""
    data = {}
    section = data
    for ln, raw in enumerate(text.splitlines(), 1):
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            section = data
            for part in line[1:-1].split("."):
                section = section.setdefault(part.strip().strip('"'), {})
            continue
        key, eq, val = line.partition("=")
        key, val = key.strip(), val.strip()
        if not eq or not key or not val:
            raise ValueError(f"{CONFIG_TOML} line {ln}: cannot parse: {raw}")
        if val[0] in "\"'":
            end = val.find(val[0], 1)
            if end < 0:
                raise ValueError(f"{CONFIG_TOML} line {ln}: unterminated string: {raw}")
            section[key] = val[1:end]
            continue
        val = val.split("#", 1)[0].strip()
        if val.lower() in ("true", "false"):
            section[key] = val.lower() == "true"
            continue
        try:
            section[key] = int(val)
        except ValueError:
            raise ValueError(f"{CONFIG_TOML} line {ln}: unsupported value (use the "
                             f"string/int/bool subset for Python < 3.11): {raw}") from None
    return data


def _config_fallback(msg):
    """A broken config must never brick every command (including --help and
    `hpc-alloc config`, the tools needed to diagnose it): warn loudly and run
    with built-in defaults instead."""
    global CONFIG_ERROR
    CONFIG_ERROR = msg
    print(f"hpc-alloc: warning: {msg} — ignoring config.toml, using built-in defaults",
          file=sys.stderr, flush=True)
    return {}


def load_config():
    if not CONFIG_TOML.exists():
        return {}
    try:
        text = CONFIG_TOML.read_text()
    except OSError as e:
        return _config_fallback(f"cannot read {CONFIG_TOML}: {e}")
    try:
        import tomllib
    except ModuleNotFoundError:
        try:
            return parse_toml_subset(text)
        except ValueError as e:
            return _config_fallback(str(e))
    try:
        return tomllib.loads(text)
    except tomllib.TOMLDecodeError as e:
        return _config_fallback(f"invalid {CONFIG_TOML}: {e}")


CONFIG_ERROR = None
CONFIG = load_config()


def cfg(*path, default=None):
    d = CONFIG
    for k in path:
        if not isinstance(d, dict) or k not in d:
            return default
        d = d[k]
    return d


def cfg_int(value, name):
    if value is None:
        return None
    if isinstance(value, bool):  # int(True) == 1 would silently pass
        die(f"{CONFIG_TOML}: {name} must be an integer, got {str(value).lower()}")
    try:
        return int(value)
    except (TypeError, ValueError):
        die(f"{CONFIG_TOML}: {name} must be an integer, got {value!r}")


def resolve_option(key, cluster, builtin=None):
    """Uniform precedence for every option: [cluster.X] > [defaults] > builtin.
    Returns (value, source) where source is 'cluster' | 'config' | 'builtin'."""
    v = cfg("cluster", cluster, key) if cluster else None
    if v is not None:
        return v, "cluster"
    v = cfg("defaults", key)
    if v is not None:
        return v, "config"
    return builtin, "builtin"


def resolve_common(args):
    """Fill options the CLI left unset from config.toml, then built-ins."""
    if getattr(args, "cluster", "") is None:
        args.cluster = cfg("defaults", "cluster") or DEFAULT_CLUSTER
    cluster = getattr(args, "cluster", None)
    if getattr(args, "time", "") is None:
        args.time = resolve_option("time", cluster, DEFAULT_TIME)[0]
        if not isinstance(args.time, str):
            die(f'{CONFIG_TOML}: time must be a quoted Slurm duration like "4:00:00", '
                f"got {args.time!r} (a bare TOML integer would mean MINUTES to Slurm)")
    if getattr(args, "cpus", "") is None:
        args.cpus = cfg_int(resolve_option("cpus", cluster)[0], "cpus") or DEFAULT_CPUS
    if getattr(args, "mem", "") is None:
        args.mem = resolve_option("mem", cluster)[0]
        if args.mem is not None and not isinstance(args.mem, str):
            die(f'{CONFIG_TOML}: mem must be a quoted string like "64G", got {args.mem!r}')


# ---------------------------------------------------------------- state

def load_state():
    if STATE_FILE.exists():
        try:
            with open(STATE_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, OSError) as e:
            die(f"{STATE_FILE} is unreadable or corrupt ({e}).\n"
                "  Fix or remove it — jobs on the cluster are unaffected, and\n"
                "  `hpc-alloc setup` + `hpc-alloc status` rediscover them.")
    return {"netid": None, "clusters": {}, "allocs": {}}


def atomic_write_600(path, text):
    """Write-if-changed via tmp+rename (a signal mid-write can't truncate the
    live file); self-heals 0600 permissions either way. Returns True if written."""
    if path.exists() and path.read_text() == text:
        path.chmod(0o600)
        return False
    tmp = path.with_suffix(".tmp")
    tmp.write_text(text)
    tmp.chmod(0o600)
    tmp.replace(path)
    return True


def save_state(state):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    atomic_write_600(STATE_FILE, json.dumps(state, indent=2))
    rebuild_ssh_config(state)


@contextmanager
def locked_state():
    """Exclusive read-modify-write of state.json. Concurrent invocations are
    normal (a backgrounded `run` racing an interactive `up`), and last-writer-
    wins would silently drop allocation records. Keep network calls outside."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    lf = open(LOCK_FILE, "w")
    fcntl.flock(lf, fcntl.LOCK_EX)
    try:
        state = load_state()
        yield state
        save_state(state)
    finally:
        fcntl.flock(lf, fcntl.LOCK_UN)
        lf.close()


def require_setup(state):
    if not state.get("netid") or not state.get("clusters"):
        die("not configured yet — run `hpc-alloc setup --netid YOUR_NETID` first")


def machine_id(state=None):
    """This machine's ownership id: 12 random hex chars generated once and kept
    in state.json — ALWAYS persisted, even for dry runs: the printed sbatch
    line must be exactly what a real submission would send, and a pasted
    command must create a job this machine actually owns. Must not be called
    while holding locked_state (it takes the lock itself to persist)."""
    state = state if state is not None else load_state()
    mid = state.get("machine_id")
    if mid:
        return mid
    mid = os.urandom(6).hex()
    with locked_state() as st:
        mid = st.setdefault("machine_id", mid)  # a concurrent generator wins
    state["machine_id"] = mid
    return mid


def machine_tag():
    """The --comment ownership tag for jobs submitted by this machine."""
    return f"hpc-alloc:{machine_id()}:{MACHINE_HOST}"


def login_alias(cluster):
    return f"{cluster}-login"


def alloc_alias(alloc):
    return f"{alloc['cluster']}-{alloc['name']}"


# ------------------------------------------------------- ssh config file

def rebuild_ssh_config(state):
    """Regenerate the managed ssh_config from state. Idempotent."""
    netid = state.get("netid") or "NETID"
    ident = cfg("ssh", "identity_file")
    id_lines = [f"    IdentityFile {ident}", "    IdentitiesOnly yes"] if ident else []
    lines = [
        "# Managed by hpc-alloc — regenerated on every change; do not edit by hand.",
        "",
    ]
    for cluster, ccfg in sorted(state.get("clusters", {}).items()):
        lines += [
            f"Host {login_alias(cluster)}",
            f"    HostName {ccfg['host']}",
            f"    User {netid}",
            *id_lines,
            "    ControlMaster auto",
            "    ControlPath ~/.ssh/hpc-alloc-%C",
            "    ControlPersist 4h",
            "    ServerAliveInterval 15",
            "    ServerAliveCountMax 3",
            "    StrictHostKeyChecking accept-new",
            "",
        ]
    for name, alloc in sorted(state.get("allocs", {}).items()):
        if not alloc.get("node"):
            continue
        lines += [
            f"Host {alloc_alias(alloc)}",
            f"    HostName {alloc['node']}",
            f"    User {netid}",
            *id_lines,
            f"    ProxyJump {login_alias(alloc['cluster'])}",
            "    ControlMaster auto",
            "    ControlPath ~/.ssh/hpc-alloc-%C",
            "    ControlPersist 4h",
            "    StrictHostKeyChecking accept-new",
            f"    UserKnownHostsFile {KNOWN_HOSTS}",
            "    ServerAliveInterval 15",
            "    ServerAliveCountMax 3",
            "",
        ]
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    atomic_write_600(SSH_CONFIG, "\n".join(lines))


def ensure_include():
    """Make ~/.ssh/config Include our managed file (prepended, once)."""
    SSH_DIR.mkdir(mode=0o700, exist_ok=True)
    existing = USER_SSH_CONFIG.read_text() if USER_SSH_CONFIG.exists() else ""
    # match an UNCOMMENTED Include line — '# Include ...' must not satisfy this
    if re.search(r"^[ \t]*Include[ \t]+~/\.config/hpc-alloc/ssh_config[ \t]*$",
                 existing, re.MULTILINE):
        return
    header = f"# hpc-alloc managed hosts\n{INCLUDE_LINE}\n\n"
    # atomic, THROUGH any symlink: a crash mid-write must not truncate the
    # user's config, and replace() on the symlink path itself would silently
    # convert a dotfiles-managed link into an independent regular file
    atomic_write_600(USER_SSH_CONFIG.resolve(), header + existing)
    info(f"added '{INCLUDE_LINE}' to {USER_SSH_CONFIG}")


# ------------------------------------------------------------- ssh plumbing

class ConnState:
    """Connection-layer knowledge accumulated during ONE hpc-alloc run.

    verified: clusters whose login connection was confirmed this run —
      try_login's fast path trusts these; login_run's failure path revokes.
    last_probe / probe_detail: outcome ('ok'|'auth'|'hostkey'|'net') and
      stderr of the most recent fresh probe. Only meaningful immediately
      after the probe/try_login call that set them (ensure_login and the
      reconnect loop read them right away; nothing else should).
    remote_now: cluster -> (cluster-local 'date' string, monotonic anchor),
      captured by squeue_all's round trip for submit_age."""

    def __init__(self):
        self.verified = set()
        self.last_probe = None
        self.probe_detail = ""
        self.remote_now = {}


CONN = ConnState()


def ssh_argv(alias, remote_cmd=None, batch=True, connect_timeout=10, extra=()):
    """The one place ssh invocations are assembled — transport-wide options
    must not be maintained in five hand-built copies."""
    argv = ["ssh"]
    if batch:
        argv += ["-o", "BatchMode=yes"]
    for opt in extra:
        argv += ["-o", opt]
    argv += ["-o", f"ConnectTimeout={connect_timeout}", "--", alias]
    if remote_cmd is not None:
        argv.append(remote_cmd)
    return argv


def can_prompt():
    """Whether interactive auth (Duo) can reach the user. ssh prompts via
    /dev/tty, not stdin — so a shell with piped stdin but a controlling
    terminal (e.g. Claude Code's `!` commands) can still authenticate."""
    if sys.stdin.isatty():
        return True
    try:
        fd = os.open("/dev/tty", os.O_RDWR)
        os.close(fd)
        return True
    except OSError:
        return False


def master_alive(cluster):
    r = subprocess.run(
        ["ssh", "-O", "check", "--", login_alias(cluster)],
        capture_output=True, text=True,
    )
    return r.returncode == 0


def close_master(alias):
    """Tear down a multiplexed master connection for an alias, if one exists."""
    subprocess.run(["ssh", "-O", "exit", "--", alias], capture_output=True, text=True)


def forget_hostkey(node):
    """Drop a node's host key: compute nodes get reimaged, and a stale key turns
    the next allocation on that node into a scary hard MITM failure."""
    if KNOWN_HOSTS.exists():
        subprocess.run(["ssh-keygen", "-R", node, "-f", str(KNOWN_HOSTS)],
                       capture_output=True, text=True)


def sweep_dead_sockets():
    """Remove control sockets whose master died (e.g. during sleep). A dead
    socket file makes OpenSSH silently disable multiplexing — Duo on every
    command — so these must be cleaned, and `-O exit` can't do it."""
    for sock in SSH_DIR.glob("hpc-alloc-*"):
        r = subprocess.run(["ssh", "-S", str(sock), "-O", "check", "unused"],
                           capture_output=True, text=True)
        if r.returncode != 0:
            try:
                sock.unlink()
            except OSError:
                pass


def heal_connections(state, cluster):
    """Close all masters for a cluster (compute nodes first, then login) and
    sweep orphaned socket files."""
    for alloc in state.get("allocs", {}).values():
        if alloc["cluster"] == cluster and alloc.get("node"):
            close_master(alloc_alias(alloc))
    close_master(login_alias(cluster))
    sweep_dead_sockets()
    CONN.verified.discard(cluster)


def probe(alias, timeout=15):
    """Test real end-to-end reachability (a live-looking master can be dead).

    Returns 'ok', 'auth' (host reachable but needs interactive auth, i.e. Duo),
    'hostkey' (host key verification failed — must be surfaced, never masked),
    or 'net' (unresolvable/unreachable/stalled)."""
    try:
        r = subprocess.run(ssh_argv(alias, "true"),
                           capture_output=True, text=True, errors="replace", timeout=timeout)
    except subprocess.TimeoutExpired:
        CONN.probe_detail = "connection stalled"
        return "net"
    if r.returncode == 0:
        CONN.probe_detail = ""
        return "ok"
    CONN.probe_detail = (r.stderr or "").strip()
    s = CONN.probe_detail.lower()
    if "host key verification failed" in s or "identification has changed" in s:
        return "hostkey"
    if "permission denied" in s or "authentication" in s:
        return "auth"
    return "net"


def probe_node(alias):
    """Probe a compute-node alias end-to-end, healing a stale node master once.
    Returns the final probe status ('ok'|'auth'|'hostkey'|'net')."""
    st = probe(alias)
    if st != "ok":
        close_master(alias)
        st = probe(alias)
    return st


def try_login(cluster, interactive=None):
    """Establish/verify the login master. Returns bool; never exits."""
    if cluster in CONN.verified:
        return True
    if interactive is None:
        interactive = can_prompt()
    alias = login_alias(cluster)
    if master_alive(cluster):
        # Trust the mux (saves an end-to-end probe on EVERY command). If it is
        # actually stale, login_run's failure path heals and retries.
        CONN.verified.add(cluster)
        return True
    st = probe(alias)  # fresh attempt; succeeds if no interactive auth needed
    CONN.last_probe = st
    if st == "ok":
        CONN.verified.add(cluster)
        return True
    if st == "auth" and interactive:
        info(f"connecting to {alias} (answer the Duo prompt in your terminal)...")
        r = subprocess.run(ssh_argv(alias, "true", batch=False, connect_timeout=30))
        if r.returncode == 0:
            CONN.verified.add(cluster)
            return True
    return False


def key_fingerprint(key):
    """The key's fingerprint (via its .pub when present), or None."""
    pub = Path(str(key) + ".pub")
    fp = subprocess.run(["ssh-keygen", "-lf", str(pub if pub.exists() else key)],
                        capture_output=True, text=True)
    toks = fp.stdout.split()
    return toks[1] if fp.returncode == 0 and len(toks) >= 2 else None


def key_in_agent(key):
    """Is this key's fingerprint loaded in the running ssh-agent?"""
    fingerprint = key_fingerprint(key)
    if not fingerprint:
        return False
    agent = subprocess.run(["ssh-add", "-l"], capture_output=True, text=True)
    return agent.returncode == 0 and fingerprint in agent.stdout


def key_needs_passphrase(key):
    """True if the private key cannot be loaded without a passphrase."""
    return subprocess.run(["ssh-keygen", "-y", "-P", "", "-f", str(key)],
                          capture_output=True).returncode != 0


def push_login(cluster, timeout=90):
    """Authenticate without any terminal: ssh re-invokes THIS script as its
    SSH_ASKPASS program, which answers "1" (Duo's push option) — the second
    factor moves entirely to the user's phone. No secret ever passes through
    here, so the pinned key must be usable non-interactively; that is checked
    up front, because askpass would otherwise feed "1" to a passphrase prompt
    and the failure would masquerade as an unapproved push."""
    alias = login_alias(cluster)
    (CONFIG_DIR / "askpass-push.sh").unlink(missing_ok=True)  # pre-refactor helper
    ident = cfg("ssh", "identity_file")
    if ident:
        key = Path(ident).expanduser()
        if key.exists() and key_needs_passphrase(key) and not key_in_agent(key):
            die(f"{key} is passphrase-protected and not loaded in an ssh-agent — "
                "no Duo push can be sent without a usable key.\n"
                f"  Either `ssh-add {key}` first, or run `hpc-alloc connect` in a terminal.",
                code=EXIT_CONNLOST)
    env = {**os.environ,
           "SSH_ASKPASS": str(Path(__file__).resolve()),
           "SSH_ASKPASS_REQUIRE": "force",
           "HPC_ALLOC_ASKPASS": "1",
           "DISPLAY": os.environ.get("DISPLAY", ":0")}
    info(f"requesting Duo push for {alias} — approve it on your phone...")
    try:
        # one auth prompt = one push: a denied/expired push must not make ssh
        # re-prompt (askpass would answer "1" again — push fatigue by design)
        r = subprocess.run(ssh_argv(alias, "true", batch=False, connect_timeout=30,
                                    extra=("NumberOfPasswordPrompts=1",)),
                           env=env, capture_output=True, text=True, timeout=timeout)
    except subprocess.TimeoutExpired:
        die("Duo push not approved in time — try again with `hpc-alloc connect --push`",
            code=EXIT_CONNLOST)
    if r.returncode != 0:
        die(f"push authentication failed: {r.stderr.strip() or 'denied'}", code=EXIT_CONNLOST)
    CONN.verified.add(cluster)
    info("Duo approved — connection established")


def ensure_login(cluster, interactive=None):
    if try_login(cluster, interactive=interactive):
        return
    if CONN.last_probe == "hostkey":
        first = CONN.probe_detail.splitlines()[0] if CONN.probe_detail else "host key mismatch"
        die("SSH HOST KEY VERIFICATION FAILED — the server's key changed.\n"
            f"  ssh said: {first}\n"
            "  If YCRC reimaged its login nodes this is expected: verify with them, then run\n"
            f"  `ssh-keygen -R <hostname>` (for compute nodes, edit {KNOWN_HOSTS}).\n"
            "  If unexpected, treat it as a possible interception and contact hpc@yale.edu.",
            code=EXIT_CONNLOST)
    if CONN.last_probe == "auth":
        if not can_prompt():
            die(f"{login_alias(cluster)} is reachable but needs interactive (Duo) auth.\n"
                "  Run `hpc-alloc connect` in a terminal, then retry.", code=EXIT_CONNLOST)
        die("authentication failed. Check that:\n"
            f"  - the right public key is uploaded at {KEY_UPLOADER} "
            f"(pinned: {cfg('ssh', 'identity_file') or 'none — ssh default order'})\n"
            "  - the Duo prompt was approved\n"
            "  - the NetID is correct (see `hpc-alloc config` and the managed ssh_config)",
            code=EXIT_CONNLOST)
    die(f"cannot reach {login_alias(cluster)} — is the Yale VPN connected?\n"
        "  (verify host/NetID via `hpc-alloc config` and ~/.config/hpc-alloc/ssh_config)",
        code=EXIT_CONNLOST)


def login_run(cluster, remote_cmd, check=True, timeout=60, _retry=True, binary=False,
              interactive=None):
    """Run a command on the login node over the multiplexed connection.

    Raises ConnectionLost on transport failure/stall (after one heal+retry).
    binary=True returns raw bytes in r.stdout — required when streaming log
    content, where strict text decoding would crash on non-UTF-8 bytes and
    newline translation would corrupt byte-offset accounting. r.stderr is
    ALWAYS text, so every caller can .strip() it into a message safely.
    interactive=False guarantees no Duo prompt anywhere in the call (required
    when sweeping secondary clusters in the background of another operation)."""
    ensure_login(cluster, interactive=interactive)
    text_kwargs = {} if binary else {"text": True, "errors": "replace"}
    try:
        r = subprocess.run(ssh_argv(login_alias(cluster), remote_cmd, connect_timeout=20),
                           capture_output=True, timeout=timeout, **text_kwargs)
    except subprocess.TimeoutExpired:
        r = None
    if r is not None and binary:
        r.stderr = r.stderr.decode(errors="replace")
    if r is None or r.returncode == 255:  # 255 = ssh transport error
        CONN.verified.discard(cluster)
        detail = "command stalled" if r is None else (r.stderr.strip() or "ssh failed")
        if _retry:
            # Evidence before healing: if the login link probes healthy, the
            # failure was the command (slow squeue, cluster-side hang, a mux
            # hiccup) — tearing down every master would kill the user's live
            # editor/shell sessions for nothing.
            if probe(login_alias(cluster)) == "ok":
                CONN.verified.add(cluster)
            else:
                # a stale master must not be re-trusted by try_login's fast path
                heal_connections(load_state(), cluster)
                if not try_login(cluster, interactive=interactive):
                    raise ConnectionLost(detail)
            return login_run(cluster, remote_cmd, check=check, timeout=timeout,
                             _retry=False, binary=binary, interactive=interactive)
        if r is None and probe(login_alias(cluster)) == "ok":
            # the remote shell is reachable but the command keeps hanging — a
            # cluster-side problem (scheduler/filesystem); reconnecting can't help
            raise SlurmError(f"remote command keeps stalling while the connection "
                             f"probes healthy ({detail})")
        # rc 255 is ssh's OWN transport-error code: classify transport-first,
        # however lucky the probes were (a flapping link fails long commands
        # while passing 1s probes — that needs the reconnect path, not a
        # 'scheduler problem, connect won't help' misdiagnosis). Heal first so
        # wait_reconnect starts from clean masters and can't be fooled into a
        # false 'reconnected' by a locally-alive mux with dead TCP.
        heal_connections(load_state(), cluster)
        raise ConnectionLost(detail)
    if check and r.returncode != 0:
        die(f"remote command failed on {login_alias(cluster)}: {remote_cmd}\n{r.stderr.strip()}")
    return r


def wait_reconnect(cluster, budget=600, interrupt_hint="Ctrl-C is safe, jobs stay queued"):
    """Patiently re-probe after a drop. Probes are NON-interactive; when the
    network returns and re-auth is needed, at most ONE interactive attempt is
    made — a reconnect loop must never strafe the user with repeated Duo
    prompts (push fatigue). True once reconnected.

    interrupt_hint must match the CALLER's Ctrl-C behavior: `run` cancels its
    job on interrupt, so promising 'safe' here would be a lie."""
    info(f"retrying for up to {budget // 60} minutes — {interrupt_hint}")
    deadline = time.monotonic() + budget
    while time.monotonic() < deadline:
        time.sleep(15)
        if try_login(cluster, interactive=False):
            info("reconnected")
            return True
        if CONN.last_probe == "hostkey":
            return False  # surfaced by ensure_login on the next command
        if CONN.last_probe == "auth":
            if can_prompt() and try_login(cluster):  # exactly one Duo attempt
                info("reconnected")
                return True
            info("network is back but re-authentication is needed — run "
                 "`hpc-alloc connect` (or `hpc-alloc connect --push`)")
            return False
    return False


# ------------------------------------------------------------- slurm helpers

# One named shape for queue rows everywhere — positional unpacks broke twice
# when the squeue format grew a field.
Job = collections.namedtuple(
    "Job", "state node reason time_left partition name submit comment")


# Unit-separator delimited: %j (job name) and %k (comment) are free text that
# users can legally put '|' into — one pipe in a job name shifted every field.
SQUEUE_SEP = "\x1f"
SQUEUE_FORMAT = SQUEUE_SEP.join(["%i", "%T", "%N", "%r", "%L", "%P", "%j", "%V", "%k"])


def parse_squeue(text):
    out = {}
    # split("\n"), not splitlines(): job names/comments are free text, and
    # Python treats \x0b/\x0c/\x1c/\x1d/\x85/U+2028/U+2029 as line breaks —
    # splitlines() fragmented such rows and the job silently vanished.
    for line in text.split("\n"):
        # no strip(): Python counts \x1f as whitespace, and stripping it would
        # drop the trailing separator of every row whose comment is empty
        parts = line.rstrip("\r").split(SQUEUE_SEP)
        if len(parts) == len(Job._fields) + 1:
            out[parts[0]] = Job(*parts[1:])
    return out


def squeue_all(cluster, interactive=None):
    """All of the user's queued/running jobs as {jobid: Job}.
    Raises ClusterError if the queue could not actually be queried — absence
    of a job is only meaningful when this returns normally.

    The same round trip captures the CLUSTER's wall clock (for submit_age).
    Both squeue's %V stamps and the clock are rendered in UTC on the cluster,
    so the client's timezone and DST folds can never skew age arithmetic
    (live-proven PT-vs-ET skew; mktime's fall-back-hour ambiguity)."""
    r = login_run(cluster, f"TZ=UTC squeue --me -h -o '{SQUEUE_FORMAT}' && "
                           "printf '\\036' && date -u +%Y-%m-%dT%H:%M:%S", check=False,
                  interactive=interactive)
    if r.returncode != 0 or "\x1e" not in r.stdout:
        raise SlurmError(f"squeue failed: {r.stderr.strip() or 'unknown error'}")
    # LAST separator: %j/%k are user free text, and an embedded RS byte must
    # not truncate the snapshot (a truncated snapshot once reaped a live
    # allocation — absence evidence must never come from framing accidents)
    text, _, now_str = r.stdout.rpartition("\x1e")
    CONN.remote_now[cluster] = (now_str.strip(), time.monotonic())
    return parse_squeue(text)


def parse_owner(comment):
    """(owner_id, owner_host) from a job's --comment ownership tag."""
    if not comment.startswith("hpc-alloc:"):
        return None, None
    parts = comment.split(":")
    return parts[1] or None, (parts[2] if len(parts) > 2 else "") or None


def submit_age(submit, cluster):
    """Seconds between a squeue %V submit stamp and the cluster's own clock
    (captured by squeue_all in the same round trip). Both stamps are UTC
    (TZ=UTC squeue / date -u) and parsed with timegm — no local timezone, no
    DST-fold ambiguity. None if either stamp is missing/unparseable."""
    clock = CONN.remote_now.get(cluster)
    if clock is None:
        return None
    now_str, anchor = clock
    try:
        now = calendar.timegm(time.strptime(now_str, "%Y-%m-%dT%H:%M:%S"))
        sub = calendar.timegm(time.strptime(submit, "%Y-%m-%dT%H:%M:%S"))
    except ValueError:
        return None
    return max(0.0, now + (time.monotonic() - anchor) - sub)


def squeue_query(cluster, jobids, interactive=None):
    """Subset of squeue_all for specific ids (full Job rows)."""
    q = squeue_all(cluster, interactive=interactive)
    return {j: q[j] for j in jobids if j in q}


def sacct_final(cluster, jobid, fields=("State", "ExitCode"), attempts=(0,), interactive=None):
    """Fetch a job's FINAL accounting record (-P parse). Returns the field list
    or None. slurmdbd commit lag routinely spans seconds (longer under load),
    during which sacct returns the stale start record (RUNNING) — non-final
    states are retried per `attempts` (delays in seconds), never trusted."""
    for delay in attempts:
        if delay:
            time.sleep(delay)
        r = login_run(cluster, f"sacct -j {jobid} -X -n -P -o {','.join(fields)}", check=False,
                      interactive=interactive)
        rec = (r.stdout.strip().splitlines() or [""])[0].split("|")
        state_words = rec[0].split()  # guard: an empty State field must retry,
        if (len(rec) >= len(fields) and state_words  # not IndexError-crash
                and state_words[0].rstrip("+") in FINAL_SACCT_STATES):
            return rec
    return None


def final_job_state(cluster, jobid, patience=True, interactive=None):
    """(state, exitcode) once accounting is FINAL, else None. patience=False
    does a single quick attempt (for watchers that don't owe anyone a verdict)."""
    rec = sacct_final(cluster, jobid, interactive=interactive,
                      attempts=[0, 2, 2, 3, 4, 5, 7, 7] if patience else [0])
    return (rec[0], rec[1]) if rec else None


def remote_home(cluster, state):
    """The user's home directory on the cluster (cached in state)."""
    cfg = state["clusters"][cluster]
    if not cfg.get("home"):
        r = login_run(cluster, 'printf "%s" "$HOME"')
        home = r.stdout.strip()
        cfg["home"] = home
        with locked_state() as st:
            st["clusters"].setdefault(cluster, {"host": cfg["host"]})["home"] = home
    return cfg["home"]


def gpu_utils(aliases, timeout=12):
    """Max GPU utilization % per alias, queried CONCURRENTLY (N sequential
    ProxyJump execs made every status pay sum-of-latencies; a single wedged
    node stalled it 15s). Failures heal the node master for the next status
    instead of retrying now. Returns {alias: percent_or_None}."""
    cmd = "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits"
    procs = {alias: subprocess.Popen(ssh_argv(alias, cmd, connect_timeout=8),
                                     stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
                                     text=True)
             for alias in aliases}
    out = {}
    deadline = time.monotonic() + timeout
    for alias, p in procs.items():
        try:
            stdout, _ = p.communicate(timeout=max(0.1, deadline - time.monotonic()))
        except subprocess.TimeoutExpired:
            p.kill()
            p.communicate()
            stdout = None
        if stdout is not None and p.returncode == 0:
            vals = [int(x) for x in stdout.split() if x.strip().isdigit()]
            out[alias] = max(vals) if vals else None
        else:
            # Heal only on transport evidence, read from ssh's OWN exit code —
            # no extra probes (serial 5s probes re-created the sum-of-latencies
            # stall this function exists to avoid). 255/stall = transport;
            # 1-254 = nvidia-smi failed over a healthy master (driver hiccup,
            # job just ended) and the user's sessions ride on that master.
            if stdout is None or p.returncode == 255:
                close_master(alias)
            out[alias] = None
    return out


def timeleft_minutes(s):
    """Parse squeue %L ([D-]HH:MM:SS, MM:SS, or minutes) to minutes, else None."""
    if not s or not s[0].isdigit():
        return None
    days = 0
    if "-" in s:
        d, s = s.split("-", 1)
        days = int(d)
    try:
        parts = [int(x) for x in s.split(":")]
    except ValueError:
        return None
    if len(parts) == 3:
        h, m, _sec = parts
    elif len(parts) == 2:
        h, (m, _sec) = 0, parts
    elif len(parts) == 1:
        h, m = 0, parts[0]
    else:
        return None
    return days * 1440 + h * 60 + m


def parse_gres(s):
    """'gpu:h200:8(S:0-1),gpu:2' -> [('h200', 8), ('gpu', 2)]."""
    return [(typ or "gpu", int(n))
            for typ, n in re.findall(r"gpu:(?:([^:,()\s]+):)?(\d+)", s or "")]


def classify_node_state(s):
    s = s.rstrip("*~#%!$@+^-").lower()
    if s.startswith("idle"):
        return "idle"
    if s.startswith("mix"):
        return "mix"
    if s.startswith(("alloc", "comp")):
        return "alloc"
    return "other"  # drain, down, maint, resv, ...


