def cmd_setup(args):
    global CONFIG
    prelim = load_state()
    netid = args.netid or prelim.get("netid")
    if not netid and sys.stdin.isatty():
        netid = input("Yale NetID: ").strip()
    if not netid:
        die("NetID required: hpc-alloc setup --netid YOUR_NETID")
    cluster = args.cluster
    host = args.host or cfg("cluster", cluster, "host") or f"{cluster}.ycrc.yale.edu"

    # SSH key: reuse an existing default key, otherwise generate ed25519.
    pubkey = None
    for cand in ["id_ed25519.pub", "id_rsa.pub", "id_ecdsa.pub"]:
        p = SSH_DIR / cand
        if p.exists():
            pubkey = p
            break
    if pubkey is None:
        keyfile = SSH_DIR / "id_ed25519"
        info("no SSH key found — generating one")
        SSH_DIR.mkdir(mode=0o700, exist_ok=True)
        genargs = ["ssh-keygen", "-t", "ed25519", "-f", str(keyfile)]
        if not sys.stdin.isatty():
            genargs += ["-N", ""]
        subprocess.run(genargs, check=True)
        pubkey = keyfile.with_suffix(".pub")

    others = [c[: -len(".pub")] for c in ["id_ed25519.pub", "id_rsa.pub", "id_ecdsa.pub"]
              if (SSH_DIR / c).exists() and (SSH_DIR / c) != pubkey]
    if others:
        info(f"pinning {pubkey.name[: -len('.pub')]}; also found: {', '.join(others)} — if a "
             "different key is registered with YCRC, edit identity_file in config.toml")
    if not CONFIG_TOML.exists():
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        keypath = str(pubkey)[: -len(".pub")]
        home = str(Path.home())
        if keypath.startswith(home + "/"):
            keypath = "~" + keypath[len(home):]
        CONFIG_TOML.write_text(CONFIG_TEMPLATE.format(identity_file=keypath,
                                                      cluster=cluster))
        CONFIG = load_config()  # so this run's ssh_config already pins the key
        info(f"wrote {CONFIG_TOML} (primary cluster + pinned SSH key; edit to taste)")

    with locked_state() as state:
        prior_netid = state.get("netid")
        state["netid"] = netid
        existing = state.setdefault("clusters", {}).get(cluster, {})
        if (prior_netid and prior_netid != netid) or existing.get("host") not in (None, host):
            existing.pop("home", None)  # cached remote home may belong to the old identity
        state["clusters"][cluster] = {**existing, "host": host}
    ensure_include()
    info(f"configured cluster '{cluster}' ({host}) for NetID '{netid}'")
    print()
    print("Your SSH public key:")
    print("  " + pubkey.read_text().strip())
    print()
    print("Next steps:")
    print(f"  1. If not done already, upload the key at {KEY_UPLOADER}")
    print("     (requires campus network or Yale VPN; allow a few minutes to propagate)")
    print(f"  2. Test the connection:   hpc-alloc connect")
    print(f"  3. Allocate a node:       hpc-alloc up --partition day --cpus 4 --time 8:00:00")


def sleeper_command(idle_minutes):
    """The sleeper job body. With idle_minutes set, self-release once every GPU
    has been <=5% utilized for that many consecutive minutes (checked per minute);
    if nvidia-smi is unavailable/failing, count the node as active, never idle."""
    if not idle_minutes:
        return "sleep infinity"
    return (
        f'echo "hpc-alloc: self-releases after {idle_minutes} min of GPU idleness"; idle=0; '
        "while true; do sleep 60; "
        'u=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null '
        "| sort -rn | head -n1); "
        # non-numeric readings ([N/A], ERR!) must count as ACTIVE, like empty ones
        'case "$u" in ""|*[!0-9]*) u=100;; esac; '
        'if [ "$u" -gt 5 ]; then idle=0; else idle=$((idle+1)); fi; '
        f'if [ "$idle" -ge {idle_minutes} ]; then echo "hpc-alloc: GPU idle timeout, releasing"; exit 0; fi; '
        "done"
    )


def resource_args(args, jobname, logfile, tag):
    out = [
        "sbatch", "--parsable",
        f"--job-name={jobname}",
        f"--comment={tag}",
        f"--time={args.time}",
        "--nodes=1", "--ntasks=1",
        f"--cpus-per-task={args.cpus}",
        "--output", logfile,
    ]
    if args.mem:
        out.append(f"--mem={args.mem}")
    if args.gpus:
        out.append(f"--gpus={args.gpus}")
    if args.constraint:
        out.append(f"--constraint={args.constraint}")
    return out


def submit_prefix():
    """Ensure the remote log dir exists and prune logs older than 30 days."""
    return (f"mkdir -p {REMOTE_LOG_DIR} && "
            f"(find {REMOTE_LOG_DIR} -name '*.log' -mtime +30 -delete 2>/dev/null || true) && ")


def build_submit(args, jobname, logfile, partition, wrap, chdir=None):
    """The complete remote sbatch command line (shared by up and run)."""
    sbatch = resource_args(args, jobname, logfile, machine_tag())
    sbatch.append(f"--partition={partition}")
    if chdir:
        sbatch.append(f"--chdir={chdir}")
    sbatch += ["--wrap", wrap]
    return submit_prefix() + " ".join(shlex.quote(a) for a in sbatch)


def pick_partition(args):
    if args.partition:
        return args.partition
    if args.gpus:
        part = resolve_option("gpu_partition", args.cluster, DEFAULT_GPU_PARTITION)[0]
        info(f"--gpus given without --partition; using '{part}'")
        return part
    return resolve_option("partition", args.cluster, DEFAULT_PARTITION)[0]


def cancel_job(cluster, jobid):
    """scancel with its outcome actually checked. Returns (ok, detail)."""
    try:
        r = login_run(cluster, f"scancel {jobid}", check=False)
    except ClusterError as e:
        return False, str(e)
    if r.returncode != 0:
        return False, r.stderr.strip() or "unknown error"
    return True, ""


def clusters_in_order(state, preferred):
    """All configured clusters, preferred first."""
    return [preferred] + [c for c in state.get("clusters", {}) if c != preferred]


def primary_cluster(state):
    """The cluster that gets FULL failure semantics (exit 3, interactive Duo):
    the configured default when it is actually among the configured clusters,
    else the sole/first configured cluster. A user whose only cluster isn't
    named like the built-in default must never have it silently demoted to
    soft-secondary treatment (status would exit 0 and never offer re-auth)."""
    clusters = list(state.get("clusters", {}))
    default = cfg("defaults", "cluster") or DEFAULT_CLUSTER
    if default in clusters or not clusters:
        return default
    return clusters[0]


def poll_cluster(c, primary):
    """Queue snapshot with the failure semantics of the cluster's role: the
    primary's errors are the caller's errors; secondaries are soft."""
    if c == primary:
        return squeue_all(c)
    return on_secondary(c, lambda: squeue_all(c, interactive=False))


def live_row(cluster, jobid, interactive=None):
    """The job's queue row, double-checking absence (two polls 3s apart) —
    the same two-observation rule as snapshot_queues/follow_job: one absent
    poll is controller-blip noise, never death evidence."""
    q = squeue_all(cluster, interactive=interactive).get(jobid)
    if q is not None:
        return q
    time.sleep(3)
    return squeue_all(cluster, interactive=interactive).get(jobid)


def on_secondary(cluster, fn):
    """Run fn() against a SECONDARY cluster, softly: never interactive, never
    fatal. An unreachable second cluster must not break operations whose answer
    lives on the first. Returns fn's result, or None with a skip note.

    Multi-cluster caveat: these paths are exercised against the offline test
    shim only — no live second cluster is available for validation."""
    if not try_login(cluster, interactive=False):
        # CONN.last_probe holds WHY (set by try_login's fresh probe): a mere
        # re-auth need must name its remedy, and a host-key mismatch is a
        # security signal that must never be reduced to 'unreachable'
        if CONN.last_probe == "auth":
            info(f"note: cluster '{cluster}' needs re-auth — run "
                 f"`hpc-alloc connect --cluster {cluster}`; skipping it for now")
        elif CONN.last_probe == "hostkey":
            info(f"WARNING: cluster '{cluster}': HOST KEY VERIFICATION FAILED — "
                 "reimage or possible interception. Verify with YCRC before "
                 "trusting it; skipping it for now")
        else:
            info(f"note: cluster '{cluster}' is unreachable — skipping it")
        return None
    try:
        return fn()
    except ClusterError as e:
        info(f"note: cluster '{cluster}' could not be queried ({e}) — skipping it")
        return None
    except SystemExit:  # a die() from deep plumbing must stay contained here
        info(f"note: cluster '{cluster}' could not be queried — skipping it")
        return None


def locate_job(state, jobid, preferred):
    """Which configured cluster hosts this job right now? Searches the preferred
    cluster first (numeric job ids are per-cluster counters and can collide);
    the preferred cluster keeps full failure semantics, secondaries are swept
    via on_secondary. Returns (cluster, row_or_None, queue_snapshot) — the
    snapshot is the located cluster's full queue, so callers never poll twice."""
    q = poll_cluster(preferred, preferred)  # hard semantics: raises, never None
    if jobid in q:
        return preferred, q[jobid], q
    for c in clusters_in_order(state, preferred)[1:]:
        q2 = poll_cluster(c, preferred)
        if q2 and jobid in q2:
            return c, q2[jobid], q2
    return preferred, None, q


def submit_job(cluster, remote_cmd):
    """sbatch --parsable submit; returns the jobid. An interrupt mid-round-trip
    may leave a queued job behind — say so instead of exiting silently."""
    try:
        r = login_run(cluster, remote_cmd)
    except KeyboardInterrupt:
        die("interrupted during submission — a job MAY already be queued; run "
            "`hpc-alloc status` (an untracked job appears in the runs list)", code=130)
    jobid = r.stdout.strip().split(";")[0]
    if not jobid.isdigit():
        die(f"unexpected sbatch output: {r.stdout.strip()}")
    return jobid


def cmd_up(args):
    name = args.name
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9_-]*", name) or name in ("login", "run"):
        die(f"invalid allocation name '{name}' ('login' and 'run' are reserved)")
    partition = pick_partition(args)

    idle = args.idle_timeout
    if args.gpus:
        if idle is None:
            idle = cfg_int(resolve_option("idle_timeout", args.cluster,
                                          DEFAULT_GPU_IDLE_MINUTES)[0], "idle_timeout")
        if idle == 0:
            idle = None
    elif idle:
        info("--idle-timeout only applies to GPU allocations (it watches nvidia-smi); ignoring")
        idle = None

    remote_cmd = build_submit(args, f"{JOB_PREFIX}{name}", f"{REMOTE_LOG_DIR}/%j.log",
                              partition, sleeper_command(idle))
    if args.dry_run:
        print(remote_cmd)
        return

    state = load_state()
    require_setup(state)
    cluster = args.cluster
    if cluster not in state["clusters"]:
        die(f"cluster '{cluster}' not configured; run: hpc-alloc setup --cluster {cluster}")

    existing = state["allocs"].get(name)
    if existing:
        try:
            # double-checked absence: a one-poll blip here would submit a
            # duplicate and silently disown the still-running sleeper
            q = live_row(existing["cluster"], existing["jobid"])
        except ClusterError as e:
            die(f"allocation '{name}' already exists (job {existing['jobid']} on "
                f"'{existing['cluster']}') and that cluster can't be checked right "
                f"now ({e}) — use a different --name, or retry once it's reachable",
                code=EXIT_CONNLOST if isinstance(e, ConnectionLost) else 1)
        if q and q.state not in ENDED_STATES:
            die(f"allocation '{name}' already exists (job {existing['jobid']}, {q.state}). "
                f"Use --name for a second one, or `hpc-alloc down {name}`.")

    jobid = submit_job(cluster, remote_cmd)
    alloc = {
        "name": name, "cluster": cluster, "jobid": jobid, "node": None,
        "partition": partition, "time": args.time, "gpus": args.gpus,
        "idle_timeout": idle,
        "created": time.strftime("%Y-%m-%d %H:%M:%S"),
    }
    stale_jobid = existing["jobid"] if existing else None
    lost_to = None
    with locked_state() as st:  # decide under the lock; network stays outside it
        cur = st["allocs"].get(name)
        if cur and cur.get("jobid") not in (stale_jobid, jobid):
            lost_to = cur["jobid"]  # concurrent creation wins; cancel ours below
        else:
            st["allocs"][name] = alloc
    if lost_to:
        outcome = f"could NOT cancel duplicate job {jobid} — run `hpc-alloc cancel {jobid}`"
        try:
            cancelled, _ = cancel_job(cluster, jobid)
            if cancelled:
                outcome = f"cancelled this duplicate submission (job {jobid})"
        except SystemExit:  # ensure_login die()d — keep ITS exit code (e.g. 3, retryable)
            info(f"error: allocation '{name}' was created concurrently (job {lost_to}); {outcome}")
            raise
        die(f"allocation '{name}' was created concurrently (job {lost_to}); {outcome}")
    extra = f", self-releases after {idle} idle GPU minutes" if idle else ""
    info(f"submitted job {jobid} on {cluster} (partition {partition}, {args.time}{extra})")

    if args.no_wait:
        info(f"not waiting; run `hpc-alloc status` later to finish SSH setup once it starts")
        return
    wait_for_running(alloc, args.wait_timeout)


def wait_for_running(alloc, timeout):
    name, cluster, jobid = alloc["name"], alloc["cluster"], alloc["jobid"]
    start = time.monotonic()
    printed_estimate = False
    misses = 0
    slurm = SlurmRetry()
    try:
        while True:
            try:
                # interactive=False: the ONLY sanctioned prompt site inside
                # this loop is wait_reconnect's single attempt below
                live = squeue_query(cluster, [jobid], interactive=False)
            except SlurmError as e:
                # transport is fine — reconnecting can't help; retry briefly
                slurm.wait_or_die(cluster, e)
                continue
            except ConnectionLost as e:
                info(f"connection lost while waiting ({e}) — job {jobid} stays queued regardless")
                if not can_prompt():
                    die("reconnect (VPN, then `hpc-alloc connect`), then run `hpc-alloc status` "
                        "to finish SSH setup", code=EXIT_CONNLOST)
                if not wait_reconnect(cluster):
                    die(f"could not reconnect. Job {jobid} remains queued; run `hpc-alloc status` "
                        "once back online.", code=EXIT_CONNLOST)
                slurm.ok()  # time offline must not count against the Slurm budget
                continue
            slurm.ok()
            q = live.get(jobid)
            seen_ended = None
            if q and q.state in ENDED_STATES:
                seen_ended = q.state  # positive evidence: keep it for the report
                q = None
            if q is None:
                # an ENDED row is conclusive; bare absence needs a second look
                # (one absent poll is controller-blip noise)
                misses += 2 if seen_ended else 1
                if misses < 2:
                    time.sleep(3)
                    continue
                try:
                    fin = final_job_state(cluster, jobid, patience=False, interactive=False)
                    final = (f"{fin[0]} (exit {fin[1]})" if fin else
                             (f"{seen_ended} (accounting record still pending)"
                              if seen_ended else "unknown (no accounting record yet)"))
                except ClusterError:
                    final = seen_ended or "unknown"
                with locked_state() as st:
                    cur = st["allocs"].get(name)
                    if cur and cur.get("jobid") == jobid:  # don't pop a replacement
                        del st["allocs"][name]
                die(f"job {jobid} ended before starting: {final}\n"
                    f"log (on the cluster): ~/{REMOTE_LOG_DIR}/{jobid}.log\n"
                    f"diagnose with: hpc-alloc why {jobid}")
            misses = 0
            st_, node, reason, time_left = q.state, q.node, q.reason, q.time_left
            if st_ == "RUNNING":
                forget_hostkey(node)
                with locked_state() as st:
                    cur = st["allocs"].get(name)
                    if cur and cur.get("jobid") == jobid:  # not a concurrent replacement
                        cur["node"] = node
                alloc["node"] = node
                finish_alloc(alloc, time_left)
                return
            elapsed = int(time.monotonic() - start)
            info(f"job {jobid}: {st_} (reason: {reason}, waited {elapsed}s)")
            if elapsed > 30 and not printed_estimate:
                try:  # best-effort: a drop here must not bypass the reconnect loop
                    r = login_run(cluster, f"squeue -j {jobid} --start -h -o '%S'",
                                  check=False, interactive=False)
                    est = r.stdout.strip()
                    if est and est != "N/A":
                        info(f"scheduler's estimated start time: {est}")
                except ClusterError:
                    pass
                printed_estimate = True
            if elapsed > timeout:
                info(f"still pending after {timeout}s — leaving job in queue.")
                info(f"check later with `hpc-alloc status`, diagnose with `hpc-alloc why {name}`, "
                     f"or cancel with `hpc-alloc down {name}`")
                return
            time.sleep(5)
    except KeyboardInterrupt:
        print(file=sys.stderr)  # newline after ^C — stdout may be piped/JSON
        info(f"interrupted — job {jobid} is still in the queue.")
        info(f"`hpc-alloc status` to check on it, `hpc-alloc down {name}` to cancel.")
        sys.exit(130)


def finish_alloc(alloc, time_left=None):
    """Node is known: verify SSH reachability and print connection info."""
    name = alloc["name"]
    alias = alloc_alias(alloc)
    for attempt in range(5):
        r = subprocess.run(ssh_argv(alias, "true", connect_timeout=15),
                           capture_output=True, text=True)
        if r.returncode == 0:
            break
        time.sleep(3)
    else:
        info(f"warning: node {alloc['node']} allocated but SSH check failed:\n{r.stderr.strip()}")
    print()
    info(f"allocation '{name}' ready: node {alloc['node']} (job {alloc['jobid']}"
         + (f", {time_left} left" if time_left else "") + ")")
    idle_note = ""
    if alloc.get("idle_timeout"):
        idle_note = (f"\n  Idle policy:  self-releases after {alloc['idle_timeout']} min of GPU"
                     " idleness (YCRC also cancels idle-GPU jobs)")
    print(f"""
  Shell:        ssh {alias}          (or: hpc-alloc ssh {name})
  Run command:  hpc-alloc ssh {name} -- nvidia-smi
  Sync code:    hpc-alloc sync {name} ./myproject '~/myproject'
  VS Code:      connect Remote-SSH to host '{alias}'
  Claude Code:  ssh {alias} then run `claude` in your project directory{idle_note}

  The node goes away when the job hits its time limit or you run `hpc-alloc down {name}`.""")


def snapshot_queues(state):
    """{cluster: {jobid: Job}} for every readable cluster.

    The default cluster keeps full failure semantics; SECONDARY clusters
    degrade softly — one unreachable cluster must not abort the whole status.
    A cluster whose queue could not be read is absent from the result, and
    nothing on it may be judged (shim-tested only: no live second cluster).
    A single absent poll is not death evidence (controller failovers blip rows
    out of squeue), so absence is confirmed with a second look."""
    primary = primary_cluster(state)
    queues = {}
    for c in state.get("clusters", {}):
        q = poll_cluster(c, primary)
        if q is not None:
            queues[c] = q
    missing = {a["cluster"] for a in state.get("allocs", {}).values()
               if a["cluster"] in queues and a.get("jobid") not in queues[a["cluster"]]}
    if missing:
        info("a tracked job is missing from the queue — confirming before cleanup")
        time.sleep(3)
        for c in sorted(missing):
            # union: presence in EITHER poll counts as alive; latest state wins
            q2 = poll_cluster(c, primary)
            if q2 is None:
                del queues[c]  # can't confirm — don't judge this cluster at all
            else:
                queues[c] = {**queues[c], **q2}
    return queues


def classify_untracked(row, my_id, age):
    """The kind ladder for a live hpcalloc-* job this machine doesn't track:
    'run' jobs end on their own; explicitly foreign-owned allocations are never
    cancel candidates; a just-submitted sleeper is usually another window's
    `up` whose record isn't written yet (the race is sub-second, and ages are
    exact via the cluster clock); everything else is an orphan holding
    resources until cancelled."""
    if row.name == JOB_PREFIX + "run":  # exact: 'hpcalloc-run2' is an alloc name
        return "run"
    owner_id, _ = parse_owner(row.comment)
    if owner_id and owner_id != my_id:
        return "other-machine"
    return "recent" if age is not None and age < 20 else "orphan"


def refresh_status(state):
    """Reconcile allocations with the queue and discover untracked hpcalloc jobs.

    Returns (rows, runs): rows = [(alloc, state_str, time_left)], runs = [dict].
    Raises ClusterError (without touching state) if the default cluster's queue
    can't be queried. The queue snapshot is taken before the lock (network
    stays outside it), so only records that already existed at snapshot time
    may be reaped — an alloc inserted by a concurrent `up` must not be judged
    by a pre-submission snapshot."""
    pre = {(n, a.get("jobid")) for n, a in state.get("allocs", {}).items()}
    my_id = machine_id(state)  # before the lock below: it may take the lock itself
    queues = snapshot_queues(state)
    rows = []
    with locked_state() as st:
        for name, alloc in sorted(list(st["allocs"].items())):
            if alloc["cluster"] not in queues:
                rows.append((alloc, "UNKNOWN (cluster unreachable)", ""))
                continue
            q = queues[alloc["cluster"]].get(alloc["jobid"])
            if q is None or q.state in ENDED_STATES:
                # only an ABSENT row is inconclusive for a post-snapshot alloc; a row
                # in an ENDED state is post-submission evidence — report the death
                if q is None and (name, alloc.get("jobid")) not in pre:
                    rows.append((alloc, "SUBMITTING", ""))  # created after our snapshot
                    continue
                if alloc.get("node"):
                    close_master(alloc_alias(alloc))
                    forget_hostkey(alloc["node"])
                rows.append((alloc, "ENDED", ""))
                del st["allocs"][name]
                continue
            st_, node, reason, time_left = q.state, q.node, q.reason, q.time_left
            if st_ == "RUNNING" and node and alloc.get("node") != node:
                if alloc.get("node"):  # Slurm requeued the job onto a different node
                    close_master(alloc_alias(alloc))
                    info(f"allocation '{name}' moved: {alloc['node']} -> {node} (requeued)")
                forget_hostkey(node)
                alloc["node"] = node
            rows.append((alloc, st_ if st_ == "RUNNING" else f"{st_} ({reason})", time_left))
        tracked = {(a.get("cluster"), a.get("jobid")) for a in st["allocs"].values()}
    runs = []
    for cluster, q in queues.items():
        for jid, row in sorted(q.items()):
            # every live hpcalloc-* job we don't track: run jobs AND orphaned
            # sleepers (e.g. a `down` whose record was lost) must stay visible
            if (not row.name.startswith(JOB_PREFIX) or (cluster, jid) in tracked
                    or row.state in ENDED_STATES):
                continue
            kind = classify_untracked(row, my_id, submit_age(row.submit, cluster))
            owner_id, owner_host = parse_owner(row.comment)
            runs.append({"jobid": jid, "cluster": cluster, "state": row.state,
                         "node": row.node or None, "partition": row.partition,
                         "time_left": row.time_left, "jobname": row.name,
                         "owner": owner_host or owner_id, "kind": kind,
                         "orphan": kind == "orphan",
                         "log": f"~/{REMOTE_LOG_DIR}/"
                                f"{'run-' if kind == 'run' else ''}{jid}.log"})
    return rows, runs


def expiring(state_str, time_left):
    mins = timeleft_minutes(time_left)
    return state_str == "RUNNING" and mins is not None and mins <= EXPIRY_WARN_MINUTES


def cmd_status(args):
    state = load_state()
    require_setup(state)
    rows, runs = refresh_status(state)
    targets = {alloc["name"]: alloc_alias(alloc) for alloc, st_, _tl in rows
               if st_ == "RUNNING" and alloc.get("gpus") and alloc.get("node")}
    by_alias = gpu_utils(list(targets.values())) if targets else {}
    utils = {name: by_alias.get(alias) for name, alias in targets.items()}
    if args.json:
        payload = [
            {**alloc, "state": st_, "time_left": tl,
             "gpu_util": utils.get(alloc["name"]),
             "expiring_soon": expiring(st_, tl),
             "alias": alloc_alias(alloc) if alloc.get("node") else None}
            for alloc, st_, tl in rows
        ]
        print(json.dumps({"allocs": payload, "runs": runs}, indent=2))
        return
    if not rows and not runs:
        info("no active allocations or run jobs")
        return
    if rows:
        fmt = "{:<12} {:<9} {:<22} {:<12} {:<14} {:<11} {:<5} {}"
        print(fmt.format("NAME", "JOB", "STATE", "PARTITION", "NODE", "LEFT", "GPU", "SSH ALIAS"))
        for alloc, st_, tl in rows:
            u = utils.get(alloc["name"])
            left = (tl or "-") + ("!" if expiring(st_, tl) else "")
            print(fmt.format(alloc["name"], alloc["jobid"], st_, alloc["partition"],
                             alloc.get("node") or "-", left,
                             f"{u}%" if u is not None else "-",
                             alloc_alias(alloc) if alloc.get("node") else "-"))
    if runs:
        print()
        fmt = "{:<9} {:<12} {:<12} {:<14} {:<11} {}"
        print(fmt.format("RUN JOB", "STATE", "PARTITION", "NODE", "LEFT", "ACTION"))
        default_cluster = cfg("defaults", "cluster") or DEFAULT_CLUSTER
        for rj in runs:
            sfx = "" if rj["cluster"] == default_cluster else f" --cluster {rj['cluster']}"
            if rj["kind"] == "run":
                hint = f"hpc-alloc logs {rj['jobid']} -f{sfx}"
            elif rj["kind"] == "recent":
                hint = f"just submitted ('{rj['jobname']}') — likely another window; re-check status"
            elif rj["kind"] == "other-machine":
                hint = f"allocation '{rj['jobname']}' created on '{rj['owner']}' — manage it there"
            else:  # a sleeper we no longer track — surface it, don't hide it
                hint = (f"UNTRACKED allocation ('{rj['jobname']}') — verify, then: "
                        f"hpc-alloc cancel {rj['jobid']}{sfx}")
            print(fmt.format(rj["jobid"], rj["state"], rj["partition"], rj["node"] or "-",
                             rj["time_left"] or "-", hint))


def pick_alloc(state, name):
    allocs = state["allocs"]
    if not allocs:
        die("no active allocations (see `hpc-alloc status`)")
    if name:
        if name not in allocs:
            die(f"no allocation named '{name}' (see `hpc-alloc status`)")
        return allocs[name]
    if len(allocs) == 1:
        return next(iter(allocs.values()))
    if "dev" in allocs:
        return allocs["dev"]
    die("multiple allocations exist — specify a name (see `hpc-alloc status`)")


def require_node(alloc):
    if not alloc.get("node"):
        die(f"allocation '{alloc['name']}' has no node yet (job {alloc['jobid']} still "
            "pending?) — run `hpc-alloc status`")


def check_node_reachable(state, alloc):
    """Probe the compute node, healing a stale node master once. Dies with a
    useful message (expired allocation vs connection trouble) if unreachable."""
    alias = alloc_alias(alloc)
    st = probe_node(alias)
    if st == "ok":
        return
    if st == "hostkey":
        first = CONN.probe_detail.splitlines()[0] if CONN.probe_detail else "host key mismatch"
        die(f"node {alloc['node']}: HOST KEY VERIFICATION FAILED — {first}\n"
            f"  If the node was reimaged this is expected: remove its entry from\n"
            f"  {KNOWN_HOSTS} and retry. If unexpected, treat it as a possible\n"
            "  interception and contact hpc@yale.edu.", code=EXIT_CONNLOST)
    try:
        live = squeue_query(alloc["cluster"], [alloc["jobid"]])
        q = live.get(alloc["jobid"])
        if q is None or q.state in ENDED_STATES:
            die(f"allocation '{alloc['name']}' has ended (walltime expiry, scancel, or the "
                "idle-GPU policy — `hpc-alloc why " + alloc["jobid"] + "` to find out). "
                "Run `hpc-alloc status` to clean up, then `hpc-alloc up` again.")
    except ClusterError:
        pass
    die(f"cannot reach node {alloc['node']} — run `hpc-alloc status` first (the job may have "
        "been requeued onto a different node), then `hpc-alloc connect` if the network dropped.",
        code=EXIT_CONNLOST)


def split_ssh_args(state, tokens):
    """`hpc-alloc ssh [NAME] [-- CMD...]`: first token is a name only if it
    matches an existing allocation; everything else is the remote command.
    A LEADING `--` forces everything after it to be the command, so a command
    that happens to start with an allocation's name is still runnable."""
    if tokens and tokens[0] == "--":
        return None, tokens[1:]
    name = None
    if tokens and tokens[0] in state["allocs"]:
        name, tokens = tokens[0], tokens[1:]
    if tokens and tokens[0] == "--":
        tokens = tokens[1:]
    return name, tokens


def cmd_ssh(args):
    state = load_state()
    require_setup(state)
    name, command = split_ssh_args(state, args.args)
    alloc = pick_alloc(state, name)
    require_node(alloc)
    ensure_login(alloc["cluster"])
    check_node_reachable(state, alloc)
    alias = alloc_alias(alloc)
    if command:
        # Space-join like ssh itself: the remote shell interprets the result,
        # so `hpc-alloc ssh dev -- 'cd proj && make'` works as written.
        os.execvp("ssh", ["ssh", "-o", "BatchMode=yes", "--", alias, " ".join(command)])
    os.execvp("ssh", ["ssh", "--", alias])


def cmd_sync(args):
    state = load_state()
    require_setup(state)
    alloc = pick_alloc(state, args.name)
    require_node(alloc)
    ensure_login(alloc["cluster"])
    check_node_reachable(state, alloc)
    alias = alloc_alias(alloc)
    src, dst = args.src, args.dst
    if args.pull:
        src, dst = f"{alias}:{src}", dst
    else:
        src, dst = src, f"{alias}:{dst}"
    rsync = ["rsync", "-az", "-e", "ssh"]  # no --info/--stats: macOS ships openrsync
    if args.delete:
        rsync.append("--delete")
    rsync += [src, dst]
    info(" ".join(rsync))
    sys.exit(subprocess.run(rsync).returncode)


def cmd_run(args):
    """Run a command as a short-lived batch job: resources are only held while
    the command executes — the GPU-idle-friendly way to use GPU partitions."""
    command = args.command
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        die("no command given — usage: hpc-alloc run [options] -- CMD ...")
    partition = pick_partition(args)
    cluster = args.cluster

    if args.dry_run:
        # keep the printed command pastable: without --chdir, sbatch runs from
        # $HOME so a relative --output is exact; with --chdir the remote home
        # can't be resolved offline
        logfile = ("$HOME/.hpc-alloc/run-%j.log" if args.chdir
                   else f"{REMOTE_LOG_DIR}/run-%j.log")
    else:
        state = load_state()
        require_setup(state)
        if cluster not in state["clusters"]:
            die(f"cluster '{cluster}' not configured; run: hpc-alloc setup --cluster {cluster}")
        home = remote_home(cluster, state)
        logfile = f"{home}/{REMOTE_LOG_DIR}/run-%j.log"
        if args.chdir and args.chdir.startswith("~"):  # Slurm --chdir doesn't expand ~
            if not re.fullmatch(r"~(/.*)?", args.chdir):
                die(f"--chdir {args.chdir!r}: '~user' paths aren't supported — use "
                    "'~/...' (your own home) or an absolute path")
            rest = args.chdir[1:].lstrip("/")
            args.chdir = f"{home}/{rest}" if rest else home

    # one arg = a shell command string (operators work); several args = exact argv,
    # so `run -- python -c 'x = 1'` survives with its quoting intact
    wrap = command[0] if len(command) == 1 else shlex.join(command)
    remote_cmd = build_submit(args, f"{JOB_PREFIX}run", logfile, partition, wrap,
                              chdir=args.chdir)
    if args.dry_run:
        print(remote_cmd)
        if args.chdir:
            info("dry-run note: the real submission resolves --output under your remote $HOME")
        return

    jobid = submit_job(cluster, remote_cmd)
    logpath = f"{REMOTE_LOG_DIR}/run-{jobid}.log"
    if args.detach:
        info(f"submitted run job {jobid} on {partition} ({args.time} limit, log: ~/{logpath})")
        info(f"follow with `hpc-alloc logs {jobid} -f`, cancel with `hpc-alloc cancel {jobid}`")
        return
    info(f"submitted run job {jobid} on {partition} ({args.time} limit, log: ~/{logpath}); "
         "Ctrl-C cancels it")
    stream_job(cluster, jobid, logpath, cancel_on_interrupt=True, verdict=True)


class Stream:
    """Byte-exact state of one log-following session (offset accounting)."""

    def __init__(self, cluster, jobid, logpath):
        self.cluster = cluster
        self.jobid = jobid
        self.logpath = logpath
        self.offset = 0
        self.last_note = 0.0
        # NEVER stat the log before the job has started: on NFS (Roberts),
        # probing the not-yet-created file caches the negative lookup on the
        # login node, and the stream then reads empty long after the job
        # wrote output.
        self.seen_active = False

    def poll(self):
        """One combined queue+log round trip; streams any new log bytes to
        stdout and returns the job's queue row (or None). A job that has not
        started only gets a periodic state note — its log is never touched.
        Raises SlurmError/ConnectionLost like login_run."""
        # ONE round trip per poll, three RS-framed parts: queue rows + OK
        # marker, the log's current byte size, and the new log chunk. The OK
        # marker distinguishes an empty queue from a failed squeue (which must
        # not read as job-ended); the size detects requeue truncation.
        if self.seen_active:
            qlog = shlex.quote(self.logpath)
            tail_part = (f"wc -c < {qlog} 2>/dev/null || echo 0; printf '\\036'; "
                         f"tail -c +{self.offset + 1} {qlog} 2>/dev/null || true")
        else:
            tail_part = "echo 0; printf '\\036'; true"
        combined = (f"squeue --me -h -o '{SQUEUE_FORMAT}' && printf OK; "
                    f"printf '\\036'; {tail_part}")
        # interactive=False: prompts inside the polling loop belong exclusively
        # to wait_reconnect's single sanctioned attempt
        r = login_run(self.cluster, combined, check=False, binary=True, interactive=False)
        # anchor on the marker SEQUENCE, not the first RS byte: job names and
        # comments are free text, and an embedded \x1e must not break framing
        head, marker, rest = r.stdout.partition(b"OK\x1e")
        if not marker:
            raise SlurmError("squeue failed mid-stream")
        size_b, _, chunk = rest.partition(b"\x1e")
        q = parse_squeue(head.decode(errors="replace")).get(self.jobid)
        if q and q.state != "RUNNING" and q.state not in ENDED_STATES:
            # PENDING/SUSPENDED/CONFIGURING/REQUEUED: nothing to tail yet —
            # say so instead of silently polling a frozen log (any tailed
            # bytes are dropped WITHOUT advancing offset: re-read next poll)
            if time.monotonic() - self.last_note > 30:
                note = f"job {self.jobid}: {q.state}"
                if q.state == "PENDING" and q.reason:
                    note += f" (reason: {q.reason})"
                info(note)
                self.last_note = time.monotonic()
            return q
        if q is not None:
            # only a PRESENT row (RUNNING, or ENDED meaning it ran) proves the
            # job started; an ABSENT row proves nothing and must not arm the
            # tail — a one-poll blip while PENDING would otherwise stat the
            # uncreated log and poison the NFS negative-lookup cache
            self.seen_active = True
        if not self.seen_active:
            return q
        try:
            size = int(size_b.strip() or b"0")
        except ValueError:
            size = None
        if size is not None and size < self.offset:
            # Slurm reopened --output in truncate mode (requeue/preemption):
            # restart from byte 0 or attempt 2's early output is silently lost.
            # (If the new log outgrows the old offset within one poll interval,
            # this check can miss — accepted residual for a 3-5s window.)
            info(f"job {self.jobid}: log restarted (requeued?) — re-streaming from the top")
            self.offset = 0
            return q  # this poll's chunk used the stale offset; re-read next poll
        # binary: raw bytes keep the offset exact (no newline translation)
        # and non-UTF-8 log content cannot crash the stream
        if chunk:
            sys.stdout.buffer.write(chunk)
            sys.stdout.buffer.flush()
            self.offset += len(chunk)
        return q

    def drain(self):
        """One last read: epilog output lands after the loop's final poll.
        Best-effort — the job is over either way."""
        try:
            r = login_run(self.cluster, f"tail -c +{self.offset + 1} "
                          f"{shlex.quote(self.logpath)} 2>/dev/null || true",
                          check=False, binary=True, interactive=False)
            if r.stdout:
                sys.stdout.buffer.write(r.stdout)
                sys.stdout.buffer.flush()
        except (ClusterError, SystemExit):  # best-effort: the job is over either way
            pass


def follow_job(s, cancel_on_interrupt):
    """Poll a Stream until its job verifiably left the queue (or its row says
    ENDED), riding out scheduler errors (bounded retry) and connection drops
    (reconnect, at most one Duo attempt)."""
    misses = 0
    slurm = SlurmRetry()
    while True:
        try:
            q = s.poll()
            slurm.ok()
        except SlurmError as e:
            # transport is fine — reconnecting can't help; retry briefly
            slurm.wait_or_die(s.cluster, e)
            continue
        except ConnectionLost as e:
            info(f"connection lost ({e}) — job {s.jobid} keeps running; log: ~/{s.logpath}")
            if not can_prompt():
                die(f"reconnect, then reattach with `hpc-alloc logs {s.jobid} -f`",
                    code=EXIT_CONNLOST)
            if not wait_reconnect(s.cluster, interrupt_hint=(
                    "Ctrl-C CANCELS the job" if cancel_on_interrupt
                    else "Ctrl-C detaches, the job keeps running")):
                die(f"could not reconnect; job {s.jobid} continues — reattach with "
                    f"`hpc-alloc logs {s.jobid} -f`", code=EXIT_CONNLOST)
            slurm.ok()  # time offline must not count against the Slurm budget
            continue
        if q and q.state in ENDED_STATES:
            return  # positive evidence: the queue itself says it ended
        if q is None:
            misses += 1
            if misses >= 2:  # absent twice in a row: it really left the queue
                return
            # one absent poll is inconclusive (controller lag/failover) —
            # ending the stream on it would strand a still-running job
        else:
            misses = 0
        time.sleep(3 if s.seen_active else 5)


def watcher_outro(cluster, jobid):
    """Pure watcher: report the outcome if cheaply available, but the stream
    itself succeeded — exit 0 (a purged accounting record is not a failure).
    SystemExit is contained too: a connection that dies right AFTER a clean
    stream must not turn the watcher's documented exit 0 into an exit 3."""
    try:
        fin = final_job_state(cluster, jobid, patience=False, interactive=False)
        if fin:
            info(f"job {jobid} ended: {fin[0]}")
    except ClusterError:
        pass
    except SystemExit:
        info(f"job {jobid} ended; the connection dropped before its final state "
             f"could be fetched — `hpc-alloc why {jobid}` has it")


def verdict_outro(cluster, jobid):
    """run's contract: mirror the job's exit code, and never report success
    without a FINAL accounting record."""
    lost = None
    fin = None
    try:
        fin = final_job_state(cluster, jobid, interactive=False)
    except ClusterError as e:
        lost = e
    except SystemExit:
        # keep the job context in the message; exit 3 via the handler below
        lost = ConnectionLost("connection lost while fetching the verdict")
    if fin:
        jstate, exitcode = fin
        code = int(exitcode.split(":")[0]) if ":" in exitcode else 0
        if jstate.split()[0].rstrip("+") != "COMPLETED" and code == 0:
            code = 1  # OOM/TIMEOUT/CANCELLED/NODE_FAIL/... must not read as success
        info(f"job {jobid} finished: {jstate} (exit {code})")
        sys.exit(code)
    if lost is not None:
        die(f"job {jobid} ended but its final state could not be fetched ({lost}) — "
            f"check `hpc-alloc why {jobid}`",
            code=EXIT_CONNLOST if isinstance(lost, ConnectionLost) else 1)
    die(f"job {jobid} left the queue but accounting shows no FINAL state after ~30s — "
        f"check `hpc-alloc why {jobid}` (not reporting success without evidence)")


def stream_job(cluster, jobid, logpath, cancel_on_interrupt=False, verdict=False):
    """Follow a batch job: show queue progress and stream its log. Ctrl-C/SIGTERM
    detaches; it cancels the job ONLY for `run` (which documents that) — `logs -f`
    must never kill what it is merely watching. verdict=True (run) additionally
    mirrors the job's final exit code and refuses to claim success without a
    FINAL accounting record; watchers (logs -f) always exit 0 after a clean
    stream — watching succeeded regardless of how the watched job ended."""
    s = Stream(cluster, jobid, logpath)
    try:
        follow_job(s, cancel_on_interrupt)
    except KeyboardInterrupt:
        print(file=sys.stderr)  # newline after ^C — stdout is the streamed log
        if not cancel_on_interrupt:
            info(f"detached — job {jobid} keeps running (reattach: `hpc-alloc logs {jobid} -f`, "
                 f"cancel: `hpc-alloc cancel {jobid}`)")
            sys.exit(130)
        info(f"cancelling job {jobid}")
        try:
            ok, detail = cancel_job(cluster, jobid)
        except SystemExit:  # ensure_login die()d: its own diagnosis is already on stderr
            ok, detail = False, "see the error above"
        if not ok:
            info(f"could not cancel ({detail}) — run `hpc-alloc cancel {jobid}` later")
        sys.exit(130)
    s.drain()
    if verdict:
        verdict_outro(cluster, jobid)
    else:
        watcher_outro(cluster, jobid)


def cmd_logs(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    target = args.target
    q0 = None
    if target in state["allocs"]:
        alloc = state["allocs"][target]
        cluster, jobid = alloc["cluster"], alloc["jobid"]
        logpath = f"{REMOTE_LOG_DIR}/{jobid}.log"
        if not args.follow:
            # the pending guard below needs the queue row for NAME targets too
            # (streaming handles pending safely on its own; a plain tail of a
            # not-yet-created log would poison the NFS negative-lookup cache)
            q0 = squeue_all(cluster).get(jobid)
    elif target.isdigit():
        jobid = target
        cluster, q0, _ = locate_job(state, jobid, cluster)
        if q0 is not None:
            # live job: derive the path from its queue row. NEVER stat the log
            # of a not-yet-started job — that poisons the login node's NFS
            # negative-lookup cache and the later stream reads empty for ages.
            is_run = q0.name == JOB_PREFIX + "run"
            logpath = f"{REMOTE_LOG_DIR}/{'run-' if is_run else ''}{jobid}.log"
        else:
            # ended job: its log already exists (or never will) — probing is
            # safe now, and the file may live on another cluster
            probe_cmd = (f'for f in {REMOTE_LOG_DIR}/run-{jobid}.log {REMOTE_LOG_DIR}/{jobid}.log; '
                         'do [ -f "$f" ] && echo "$f" && break; done')
            r = login_run(cluster, probe_cmd, check=False)
            logpath = r.stdout.strip()
            if not logpath:
                for c in clusters_in_order(state, cluster)[1:]:
                    r = on_secondary(c, lambda c=c: login_run(
                        c, probe_cmd, check=False, interactive=False))
                    if r is not None and r.stdout.strip():
                        cluster, logpath = c, r.stdout.strip()
                        break
            logpath = logpath or f"{REMOTE_LOG_DIR}/run-{jobid}.log"
    else:
        die(f"'{target}' is neither an allocation name nor a job id")
    if args.follow:
        stream_job(cluster, jobid, logpath)  # Ctrl-C detaches; never cancels
        return
    if q0 is not None and q0.state != "RUNNING" and q0.state not in ENDED_STATES:
        die(f"job {jobid} is {q0.state} — no log to show yet; "
            f"`hpc-alloc logs {jobid} -f` streams it once the job starts")
    r = login_run(cluster, f"tail -n {args.lines} {shlex.quote(logpath)}", check=False, binary=True)
    if r.returncode != 0:
        die(f"no log at ~/{logpath} on {cluster}: {r.stderr.strip()}")
    sys.stdout.buffer.write(r.stdout)
    sys.stdout.buffer.flush()


def cmd_cancel(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    jobid = args.jobid
    if not jobid.isdigit():
        die(f"'{jobid}' is not a job id (for named allocations use `hpc-alloc down NAME`)")
    cluster, q, _ = locate_job(state, jobid, cluster)
    if q is None:
        r = login_run(cluster, f"sacct -j {jobid} -X -n -P -o JobName", check=False)
        jname = (r.stdout.strip().splitlines() or [""])[0]
        if not jname.startswith(JOB_PREFIX):
            # ids are per-cluster: the finished job may be another cluster's
            for c in clusters_in_order(state, cluster)[1:]:
                r2 = on_secondary(c, lambda c=c: login_run(
                    c, f"sacct -j {jobid} -X -n -P -o JobName", check=False,
                    interactive=False))
                jn = (r2.stdout.strip().splitlines() or [""])[0] if r2 else ""
                if jn.startswith(JOB_PREFIX):
                    jname = jn
                    break
        if jname.startswith(JOB_PREFIX):
            info(f"job {jobid} has already finished")
            return
        die(f"job {jobid} not found among your jobs")
    if not q.name.startswith(JOB_PREFIX):
        die(f"refusing: job {jobid} ('{q.name}') was not created by hpc-alloc")
    ok, detail = cancel_job(cluster, jobid)
    if not ok:
        die(f"scancel failed for job {jobid}: {detail} — retry")
    with locked_state() as st:
        for n, a in list(st["allocs"].items()):
            if a["jobid"] == jobid and a["cluster"] == cluster:
                if a.get("node"):
                    close_master(alloc_alias(a))
                del st["allocs"][n]
    info(f"cancelled job {jobid}")


def cmd_down(args):
    state = load_state()
    require_setup(state)
    names = list(state["allocs"]) if args.all else [args.name or pick_alloc(state, None)["name"]]
    if not names:
        info("no active allocations")
        return
    failed = 0
    for name in names:
        alloc = state["allocs"].get(name)
        if not alloc:
            info(f"no allocation named '{name}'")
            continue
        try:
            ok, detail = cancel_job(alloc["cluster"], alloc["jobid"])
        except SystemExit:
            if not args.all:
                raise  # single target: the diagnosis AND its exit code stand
            # with --all the OTHER clusters' allocations must still be released
            ok, detail = False, "see the error above"
        if not ok:
            info(f"scancel FAILED for job {alloc['jobid']} ('{name}'): {detail} "
                 "— keeping it in state, retry later")
            failed += 1
            continue
        if alloc.get("node"):
            close_master(alloc_alias(alloc))
        with locked_state() as st:
            cur = st["allocs"].get(name)
            if cur and cur.get("jobid") == alloc["jobid"]:  # don't pop a concurrent replacement
                del st["allocs"][name]
        info(f"cancelled job {alloc['jobid']} ('{name}')")
    if failed:
        sys.exit(1)  # scripts must not read a failed release as success


def cmd_connect(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    if args.reset:
        heal_connections(state, cluster)
        info("closed login and compute-node master connections; swept dead sockets")
    if args.push:
        # End-to-end evidence, not the master fast path: --push exists for
        # re-auth after sleep/VPN drop — exactly when a master looks alive but
        # its TCP is dead, and the fast path would silently swallow the push.
        alias = login_alias(cluster)
        st = probe(alias)
        if st != "ok" and master_alive(cluster):
            heal_connections(state, cluster)  # dead master shadowing the alias
            st = probe(alias)
        if st == "ok":
            CONN.verified.add(cluster)
        elif st == "auth":
            push_login(cluster)
        # 'net'/'hostkey': a push cannot help — fall through to ensure_login,
        # whose diagnosis (VPN down / host key changed) is the accurate one.
    ensure_login(cluster)
    r = login_run(cluster, "hostname")
    info(f"login OK: {r.stdout.strip()} (multiplexed — no Duo again for ~4h of idle)")
    for name, alloc in sorted(state["allocs"].items()):
        if alloc["cluster"] != cluster or not alloc.get("node"):
            continue
        st = probe_node(alloc_alias(alloc))
        if st == "ok":
            info(f"node {alloc['node']} ('{name}'): OK")
        elif st == "hostkey":
            info(f"node {alloc['node']} ('{name}'): HOST KEY CHANGED — verify (reimage vs "
                 f"interception), then remove its entry from {KNOWN_HOSTS}")
        else:
            info(f"node {alloc['node']} ('{name}'): unreachable — allocation may have ended; "
                 "run `hpc-alloc status`")


def cmd_partitions(args):
    state = load_state()
    require_setup(state)
    r = login_run(args.cluster, "sinfo -o '%P|%a|%l|%D|%c|%m|%G|%f'")
    rows = [l.split("|") for l in r.stdout.strip().splitlines()]
    if args.json:
        keys = ["partition", "avail", "timelimit", "nodes", "cpus", "memory", "gres", "features"]
        print(json.dumps([dict(zip(keys, row)) for row in rows[1:] if len(row) == len(keys)],
