#!/usr/bin/env python3
"""Thin executable launcher for hpc-alloc."""

from __future__ import annotations

import os
import sys
from pathlib import Path


# OpenSSH re-enters this exact executable as SSH_ASKPASS during `connect --push`.
# Answer before importing the application so broken configuration cannot pollute
# stdout or prevent the one permitted push response.
if (
    os.environ.get("HPC_ALLOC_ASKPASS") == "1"
    and os.path.realpath(os.environ.get("SSH_ASKPASS", ""))
    == os.path.realpath(__file__)
):
    print("1")
    raise SystemExit(0)

if sys.version_info < (3, 11):
    print("hpc-alloc: error: Python 3.11 or newer is required", file=sys.stderr)
    raise SystemExit(1)

from hpc_alloc.cli import main


if __name__ == "__main__":
    raise SystemExit(main(entrypoint=Path(__file__).resolve()))
