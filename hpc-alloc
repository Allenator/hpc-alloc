def cmd_setup(args):
    global CONFIG
    prelim = load_state()
    netid = args.netid or prelim.get("netid")
    if not netid and sys.stdin.isatty():
        netid = input("Yale NetID: ").strip()
    if not netid:
        die("NetID required: hpc-alloc setup --netid YOUR_NETID")
    cluster = args.cluster
    host = args.host or cfg("cluster", cluster, "host") or f"{cluster}.ycrc.yale.edu"

    # SSH key: reuse an existing default key, otherwise generate ed25519.
    pubkey = None
    for cand in ["id_ed25519.pub", "id_rsa.pub", "id_ecdsa.pub"]:
        p = SSH_DIR / cand
        if p.exists():
            pubkey = p
            break
    if pubkey is None:
        keyfile = SSH_DIR / "id_ed25519"
        info("no SSH key found — generating one")
        SSH_DIR.mkdir(mode=0o700, exist_ok=True)
        genargs = ["ssh-keygen", "-t", "ed25519", "-f", str(keyfile)]
        if not sys.stdin.isatty():
            genargs += ["-N", ""]
        subprocess.run(genargs, check=True)
        pubkey = keyfile.with_suffix(".pub")

    others = [c[: -len(".pub")] for c in ["id_ed25519.pub", "id_rsa.pub", "id_ecdsa.pub"]
              if (SSH_DIR / c).exists() and (SSH_DIR / c) != pubkey]
    if others:
        info(f"pinning {pubkey.name[: -len('.pub')]}; also found: {', '.join(others)} — if a "
             "different key is registered with YCRC, edit identity_file in config.toml")
    if not CONFIG_TOML.exists():
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        keypath = str(pubkey)[: -len(".pub")]
        home = str(Path.home())
        if keypath.startswith(home + "/"):
            keypath = "~" + keypath[len(home):]
        CONFIG_TOML.write_text(CONFIG_TEMPLATE.format(identity_file=keypath))
        CONFIG = load_config()  # so this run's ssh_config already pins the key
        info(f"wrote {CONFIG_TOML} (defaults + pinned SSH key; edit to taste)")

    with locked_state() as state:
        prior_netid = state.get("netid")
        state["netid"] = netid
        existing = state.setdefault("clusters", {}).get(cluster, {})
        if (prior_netid and prior_netid != netid) or existing.get("host") not in (None, host):
            existing.pop("home", None)  # cached remote home may belong to the old identity
        state["clusters"][cluster] = {**existing, "host": host}
    ensure_include()
    info(f"configured cluster '{cluster}' ({host}) for NetID '{netid}'")
    print()
    print("Your SSH public key:")
    print("  " + pubkey.read_text().strip())
    print()
    print("Next steps:")
    print(f"  1. If not done already, upload the key at {KEY_UPLOADER}")
    print("     (requires campus network or Yale VPN; allow a few minutes to propagate)")
    print(f"  2. Test the connection:   hpc-alloc connect")
    print(f"  3. Allocate a node:       hpc-alloc up --partition day --cpus 4 --time 8:00:00")


def sleeper_command(idle_minutes):
    """The sleeper job body. With idle_minutes set, self-release once every GPU
    has been <=5% utilized for that many consecutive minutes (checked per minute);
    if nvidia-smi is unavailable/failing, count the node as active, never idle."""
    if not idle_minutes:
        return "sleep infinity"
    return (
        f'echo "hpc-alloc: self-releases after {idle_minutes} min of GPU idleness"; idle=0; '
        "while true; do sleep 60; "
        'u=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null '
        "| sort -rn | head -n1); "
        # non-numeric readings ([N/A], ERR!) must count as ACTIVE, like empty ones
        'case "$u" in ""|*[!0-9]*) u=100;; esac; '
        'if [ "$u" -gt 5 ]; then idle=0; else idle=$((idle+1)); fi; '
        f'if [ "$idle" -ge {idle_minutes} ]; then echo "hpc-alloc: GPU idle timeout, releasing"; exit 0; fi; '
        "done"
    )


def resource_args(args, jobname, logfile):
    out = [
        "sbatch", "--parsable",
        f"--job-name={jobname}",
        f"--comment=hpc-alloc:{MACHINE_ID}",
        f"--time={args.time}",
        "--nodes=1", "--ntasks=1",
        f"--cpus-per-task={args.cpus}",
        "--output", logfile,
    ]
    if args.mem:
        out.append(f"--mem={args.mem}")
    if args.gpus:
        out.append(f"--gpus={args.gpus}")
    if args.constraint:
        out.append(f"--constraint={args.constraint}")
    return out


def submit_prefix():
    """Ensure the remote log dir exists and prune logs older than 30 days."""
    return (f"mkdir -p {REMOTE_LOG_DIR} && "
            f"(find {REMOTE_LOG_DIR} -name '*.log' -mtime +30 -delete 2>/dev/null || true) && ")


def pick_partition(args):
    if args.partition:
        return args.partition
    if args.gpus:
        part = resolve_option("gpu_partition", args.cluster, DEFAULT_GPU_PARTITION)[0]
        info(f"--gpus given without --partition; using '{part}'")
        return part
    return resolve_option("partition", args.cluster, DEFAULT_PARTITION)[0]


def cancel_job(cluster, jobid):
    """scancel with its outcome actually checked. Returns (ok, detail)."""
    try:
        r = login_run(cluster, f"scancel {jobid}", check=False)
    except ConnectionLost as e:
        return False, f"connection lost ({e})"
    if r.returncode != 0:
        return False, r.stderr.strip() or "unknown error"
    return True, ""


def locate_job(state, jobid, preferred):
    """Which configured cluster hosts this job right now? Searches the preferred
    cluster first (numeric job ids are per-cluster counters and can collide).
    Returns (cluster, row_or_None)."""
    order = [preferred] + [c for c in state.get("clusters", {}) if c != preferred]
    for c in order:
        q = squeue_all(c).get(jobid)
        if q is not None:
            return c, q
    return preferred, None


def submit_job(cluster, remote_cmd):
    """sbatch --parsable submit; returns the jobid. An interrupt mid-round-trip
    may leave a queued job behind — say so instead of exiting silently."""
    try:
        r = login_run(cluster, remote_cmd)
    except KeyboardInterrupt:
        die("interrupted during submission — a job MAY already be queued; run "
            "`hpc-alloc status` (an untracked job appears in the runs list)", code=130)
    jobid = r.stdout.strip().split(";")[0]
    if not jobid.isdigit():
        die(f"unexpected sbatch output: {r.stdout.strip()}")
    return jobid


def cmd_up(args):
    name = args.name
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9_-]*", name) or name in ("login", "run"):
        die(f"invalid allocation name '{name}' ('login' and 'run' are reserved)")
    partition = pick_partition(args)

    idle = args.idle_timeout
    if args.gpus:
        if idle is None:
            idle = cfg_int(resolve_option("idle_timeout", args.cluster,
                                          DEFAULT_GPU_IDLE_MINUTES)[0], "idle_timeout")
        if idle == 0:
            idle = None
    elif idle:
        info("--idle-timeout only applies to GPU allocations (it watches nvidia-smi); ignoring")
        idle = None

    sbatch = resource_args(args, f"{JOB_PREFIX}{name}", f"{REMOTE_LOG_DIR}/%j.log")
    sbatch += [f"--partition={partition}", "--wrap", sleeper_command(idle)]
    remote_cmd = submit_prefix() + " ".join(shlex.quote(a) for a in sbatch)
    if args.dry_run:
        print(remote_cmd)
        return

    state = load_state()
    require_setup(state)
    cluster = args.cluster
    if cluster not in state["clusters"]:
        die(f"cluster '{cluster}' not configured; run: hpc-alloc setup --cluster {cluster}")

    existing = state["allocs"].get(name)
    if existing:
        live = squeue_query(existing["cluster"], [existing["jobid"]])
        q = live.get(existing["jobid"])
        if q and q.state not in ENDED_STATES:
            die(f"allocation '{name}' already exists (job {existing['jobid']}, {q.state}). "
                f"Use --name for a second one, or `hpc-alloc down {name}`.")

    jobid = submit_job(cluster, remote_cmd)
    alloc = {
        "name": name, "cluster": cluster, "jobid": jobid, "node": None,
        "partition": partition, "time": args.time, "gpus": args.gpus,
        "idle_timeout": idle,
        "created": time.strftime("%Y-%m-%d %H:%M:%S"),
    }
    stale_jobid = existing["jobid"] if existing else None
    lost_to = None
    with locked_state() as st:  # decide under the lock; network stays outside it
        cur = st["allocs"].get(name)
        if cur and cur.get("jobid") not in (stale_jobid, jobid):
            lost_to = cur["jobid"]  # concurrent creation wins; cancel ours below
        else:
            st["allocs"][name] = alloc
    if lost_to:
        try:
            cancelled, _ = cancel_job(cluster, jobid)
        except SystemExit:  # ensure_login die()d; its diagnosis is already printed
            cancelled = False
        outcome = (f"cancelled this duplicate submission (job {jobid})" if cancelled else
                   f"could NOT cancel duplicate job {jobid} — run `hpc-alloc cancel {jobid}`")
        die(f"allocation '{name}' was created concurrently (job {lost_to}); {outcome}")
    extra = f", self-releases after {idle} idle GPU minutes" if idle else ""
    info(f"submitted job {jobid} on {cluster} (partition {partition}, {args.time}{extra})")

    if args.no_wait:
        info(f"not waiting; run `hpc-alloc status` later to finish SSH setup once it starts")
        return
    wait_for_running(alloc, args.wait_timeout)


def wait_for_running(alloc, timeout):
    name, cluster, jobid = alloc["name"], alloc["cluster"], alloc["jobid"]
    start = time.monotonic()
    printed_estimate = False
    misses = 0
    try:
        while True:
            try:
                live = squeue_query(cluster, [jobid])
            except ConnectionLost as e:
                info(f"connection lost while waiting ({e}) — job {jobid} stays queued regardless")
                if not can_prompt():
                    die("reconnect (VPN, then `hpc-alloc connect`), then run `hpc-alloc status` "
                        "to finish SSH setup", code=EXIT_CONNLOST)
                if not wait_reconnect(cluster):
                    die(f"could not reconnect. Job {jobid} remains queued; run `hpc-alloc status` "
                        "once back online.", code=EXIT_CONNLOST)
                continue
            q = live.get(jobid)
            if q and q.state in ENDED_STATES:
                q = None
            if q is None:
                misses += 1
                if misses < 2:  # one absent poll is inconclusive (controller lag/failover)
                    time.sleep(3)
                    continue
                try:
                    fin = final_job_state(cluster, jobid, patience=False)
                    final = (f"{fin[0]} (exit {fin[1]})" if fin
                             else "unknown (no accounting record yet)")
                except ConnectionLost:
                    final = "unknown"
                with locked_state() as st:
                    cur = st["allocs"].get(name)
                    if cur and cur.get("jobid") == jobid:  # don't pop a replacement
                        del st["allocs"][name]
                die(f"job {jobid} ended before starting: {final}\n"
                    f"log (on the cluster): ~/{REMOTE_LOG_DIR}/{jobid}.log\n"
                    f"diagnose with: hpc-alloc why {jobid}")
            misses = 0
            st_, node, reason, time_left = q.state, q.node, q.reason, q.time_left
            if st_ == "RUNNING":
                forget_hostkey(node)
                with locked_state() as st:
                    cur = st["allocs"].get(name)
                    if cur and cur.get("jobid") == jobid:  # not a concurrent replacement
                        cur["node"] = node
                alloc["node"] = node
                finish_alloc(alloc, time_left)
                return
            elapsed = int(time.monotonic() - start)
            info(f"job {jobid}: {st_} (reason: {reason}, waited {elapsed}s)")
            if elapsed > 30 and not printed_estimate:
                try:  # best-effort: a drop here must not bypass the reconnect loop
                    r = login_run(cluster, f"squeue -j {jobid} --start -h -o '%S'", check=False)
                    est = r.stdout.strip()
                    if est and est != "N/A":
                        info(f"scheduler's estimated start time: {est}")
                except ConnectionLost:
                    pass
                printed_estimate = True
            if elapsed > timeout:
                info(f"still pending after {timeout}s — leaving job in queue.")
                info(f"check later with `hpc-alloc status`, diagnose with `hpc-alloc why {name}`, "
                     f"or cancel with `hpc-alloc down {name}`")
                return
            time.sleep(5)
    except KeyboardInterrupt:
        print()
        info(f"interrupted — job {jobid} is still in the queue.")
        info(f"`hpc-alloc status` to check on it, `hpc-alloc down {name}` to cancel.")
        sys.exit(130)


def finish_alloc(alloc, time_left=None):
    """Node is known: verify SSH reachability and print connection info."""
    name = alloc["name"]
    alias = alloc_alias(alloc)
    for attempt in range(5):
        r = subprocess.run(ssh_argv(alias, "true", connect_timeout=15),
                           capture_output=True, text=True)
        if r.returncode == 0:
            break
        time.sleep(3)
    else:
        info(f"warning: node {alloc['node']} allocated but SSH check failed:\n{r.stderr.strip()}")
    print()
    info(f"allocation '{name}' ready: node {alloc['node']} (job {alloc['jobid']}"
         + (f", {time_left} left" if time_left else "") + ")")
    idle_note = ""
    if alloc.get("idle_timeout"):
        idle_note = (f"\n  Idle policy:  self-releases after {alloc['idle_timeout']} min of GPU"
                     " idleness (YCRC also cancels idle-GPU jobs)")
    print(f"""
  Shell:        ssh {alias}          (or: hpc-alloc ssh {name})
  Run command:  hpc-alloc ssh {name} -- nvidia-smi
  Sync code:    hpc-alloc sync {name} ./myproject '~/myproject'
  VS Code:      connect Remote-SSH to host '{alias}'
  Claude Code:  ssh {alias} then run `claude` in your project directory{idle_note}

  The node goes away when the job hits its time limit or you run `hpc-alloc down {name}`.""")


def refresh_status(state):
    """Reconcile allocations with the queue and discover untracked hpcalloc jobs.

    Returns (rows, runs): rows = [(alloc, state_str, time_left)], runs = [dict].
    Raises ConnectionLost (without touching state) if a queue can't be queried.
    The queue snapshot is taken before the lock (network stays outside it), so
    only records that already existed at snapshot time may be reaped — an alloc
    inserted by a concurrent `up` must not be judged by a pre-submission snapshot."""
    pre = {(n, a.get("jobid")) for n, a in state.get("allocs", {}).items()}
    queues = {c: squeue_all(c) for c in state.get("clusters", {})}
    rows = []
    with locked_state() as st:
        for name, alloc in sorted(list(st["allocs"].items())):
            q = queues.get(alloc["cluster"], {}).get(alloc["jobid"])
            if q is None or q.state in ENDED_STATES:
                # only an ABSENT row is inconclusive for a post-snapshot alloc; a row
                # in an ENDED state is post-submission evidence — report the death
                if q is None and (name, alloc.get("jobid")) not in pre:
                    rows.append((alloc, "SUBMITTING", ""))  # created after our snapshot
                    continue
                if alloc.get("node"):
                    close_master(alloc_alias(alloc))
                    forget_hostkey(alloc["node"])
                rows.append((alloc, "ENDED", ""))
                del st["allocs"][name]
                continue
            st_, node, reason, time_left = q.state, q.node, q.reason, q.time_left
            if st_ == "RUNNING" and node and alloc.get("node") != node:
                if alloc.get("node"):  # Slurm requeued the job onto a different node
                    close_master(alloc_alias(alloc))
                    info(f"allocation '{name}' moved: {alloc['node']} -> {node} (requeued)")
                forget_hostkey(node)
                alloc["node"] = node
            rows.append((alloc, st_ if st_ == "RUNNING" else f"{st_} ({reason})", time_left))
        tracked = {(a.get("cluster"), a.get("jobid")) for a in st["allocs"].values()}
    runs = []
    for cluster, q in queues.items():
        for jid, row in sorted(q.items()):
            # every live hpcalloc-* job we don't track: run jobs AND orphaned
            # sleepers (e.g. a `down` whose record was lost) must stay visible
            if (not row.name.startswith(JOB_PREFIX) or (cluster, jid) in tracked
                    or row.state in ENDED_STATES):
                continue
            owner = job_owner(row.comment)
            is_run = row.name == JOB_PREFIX + "run"  # exact: 'hpcalloc-run2' is an alloc name
            if is_run:
                kind = "run"
            elif owner and owner != MACHINE_ID:
                kind = "other-machine"  # explicit ownership: never a cancel candidate
            else:
                age = submit_age(row.submit)
                # a just-submitted sleeper is usually an `up` from another window
                # whose record isn't written yet — never offer to cancel those
                kind = "recent" if age is not None and age < 120 else "orphan"
            runs.append({"jobid": jid, "cluster": cluster, "state": row.state,
                         "node": row.node or None, "partition": row.partition,
                         "time_left": row.time_left, "jobname": row.name,
                         "owner": owner, "kind": kind, "orphan": kind == "orphan",
                         "log": f"~/{REMOTE_LOG_DIR}/{'run-' if is_run else ''}{jid}.log"})
    return rows, runs


def expiring(state_str, time_left):
    mins = timeleft_minutes(time_left)
    return state_str == "RUNNING" and mins is not None and mins <= EXPIRY_WARN_MINUTES


def cmd_status(args):
    state = load_state()
    require_setup(state)
    rows, runs = refresh_status(state)
    utils = {}
    for alloc, st_, _tl in rows:
        if st_ == "RUNNING" and alloc.get("gpus") and alloc.get("node"):
            utils[alloc["name"]] = gpu_util(alloc_alias(alloc))
    if args.json:
        payload = [
            {**alloc, "state": st_, "time_left": tl,
             "gpu_util": utils.get(alloc["name"]),
             "expiring_soon": expiring(st_, tl),
             "alias": alloc_alias(alloc) if alloc.get("node") else None}
            for alloc, st_, tl in rows
        ]
        print(json.dumps({"allocs": payload, "runs": runs}, indent=2))
        return
    if not rows and not runs:
        info("no active allocations or run jobs")
        return
    if rows:
        fmt = "{:<12} {:<9} {:<22} {:<12} {:<14} {:<11} {:<5} {}"
        print(fmt.format("NAME", "JOB", "STATE", "PARTITION", "NODE", "LEFT", "GPU", "SSH ALIAS"))
        for alloc, st_, tl in rows:
            u = utils.get(alloc["name"])
            left = (tl or "-") + ("!" if expiring(st_, tl) else "")
            print(fmt.format(alloc["name"], alloc["jobid"], st_, alloc["partition"],
                             alloc.get("node") or "-", left,
                             f"{u}%" if u is not None else "-",
                             alloc_alias(alloc) if alloc.get("node") else "-"))
    if runs:
        print()
        fmt = "{:<9} {:<12} {:<12} {:<14} {:<11} {}"
        print(fmt.format("RUN JOB", "STATE", "PARTITION", "NODE", "LEFT", "ACTION"))
        default_cluster = cfg("defaults", "cluster") or DEFAULT_CLUSTER
        for rj in runs:
            sfx = "" if rj["cluster"] == default_cluster else f" --cluster {rj['cluster']}"
            if rj["kind"] == "run":
                hint = f"hpc-alloc logs {rj['jobid']} -f{sfx}"
            elif rj["kind"] == "recent":
                hint = f"just submitted ('{rj['jobname']}') — likely another window; re-check status"
            elif rj["kind"] == "other-machine":
                hint = f"allocation '{rj['jobname']}' created on '{rj['owner']}' — manage it there"
            else:  # a sleeper we no longer track — surface it, don't hide it
                hint = (f"UNTRACKED allocation ('{rj['jobname']}') — verify, then: "
                        f"hpc-alloc cancel {rj['jobid']}{sfx}")
            print(fmt.format(rj["jobid"], rj["state"], rj["partition"], rj["node"] or "-",
                             rj["time_left"] or "-", hint))


def pick_alloc(state, name):
    allocs = state["allocs"]
    if not allocs:
        die("no active allocations (see `hpc-alloc status`)")
    if name:
        if name not in allocs:
            die(f"no allocation named '{name}' (see `hpc-alloc status`)")
        return allocs[name]
    if len(allocs) == 1:
        return next(iter(allocs.values()))
    if "dev" in allocs:
        return allocs["dev"]
    die("multiple allocations exist — specify a name (see `hpc-alloc status`)")


def require_node(alloc):
    if not alloc.get("node"):
        die(f"allocation '{alloc['name']}' has no node yet (job {alloc['jobid']} still "
            "pending?) — run `hpc-alloc status`")


def check_node_reachable(state, alloc):
    """Probe the compute node, healing a stale node master once. Dies with a
    useful message (expired allocation vs connection trouble) if unreachable."""
    alias = alloc_alias(alloc)
    st = probe(alias)
    if st != "ok":
        close_master(alias)
        st = probe(alias)
    if st == "ok":
        return
    if st == "hostkey":
        first = _probe_detail.splitlines()[0] if _probe_detail else "host key mismatch"
        die(f"node {alloc['node']}: HOST KEY VERIFICATION FAILED — {first}\n"
            f"  If the node was reimaged this is expected: remove its entry from\n"
            f"  {KNOWN_HOSTS} and retry. If unexpected, treat it as a possible\n"
            "  interception and contact hpc@yale.edu.", code=EXIT_CONNLOST)
    try:
        live = squeue_query(alloc["cluster"], [alloc["jobid"]])
        q = live.get(alloc["jobid"])
        if q is None or q.state in ENDED_STATES:
            die(f"allocation '{alloc['name']}' has ended (walltime expiry, scancel, or the "
                "idle-GPU policy — `hpc-alloc why " + alloc["jobid"] + "` to find out). "
                "Run `hpc-alloc status` to clean up, then `hpc-alloc up` again.")
    except ConnectionLost:
        pass
    die(f"cannot reach node {alloc['node']} — run `hpc-alloc status` first (the job may have "
        "been requeued onto a different node), then `hpc-alloc connect` if the network dropped.",
        code=EXIT_CONNLOST)


def split_ssh_args(state, tokens):
    """`hpc-alloc ssh [NAME] [-- CMD...]`: first token is a name only if it
    matches an existing allocation; everything else is the remote command."""
    if tokens and tokens[0] == "--":
        tokens = tokens[1:]
    name = None
    if tokens and tokens[0] in state["allocs"]:
        name, tokens = tokens[0], tokens[1:]
    if tokens and tokens[0] == "--":
        tokens = tokens[1:]
    return name, tokens


def cmd_ssh(args):
    state = load_state()
    require_setup(state)
    name, command = split_ssh_args(state, args.args)
    alloc = pick_alloc(state, name)
    require_node(alloc)
    ensure_login(alloc["cluster"])
    check_node_reachable(state, alloc)
    alias = alloc_alias(alloc)
    if command:
        # Space-join like ssh itself: the remote shell interprets the result,
        # so `hpc-alloc ssh dev -- 'cd proj && make'` works as written.
        os.execvp("ssh", ["ssh", "-o", "BatchMode=yes", "--", alias, " ".join(command)])
    os.execvp("ssh", ["ssh", "--", alias])


def cmd_sync(args):
    state = load_state()
    require_setup(state)
    alloc = pick_alloc(state, args.name)
    require_node(alloc)
    ensure_login(alloc["cluster"])
    check_node_reachable(state, alloc)
    alias = alloc_alias(alloc)
    src, dst = args.src, args.dst
    if args.pull:
        src, dst = f"{alias}:{src}", dst
    else:
        src, dst = src, f"{alias}:{dst}"
    rsync = ["rsync", "-az", "-e", "ssh"]  # no --info/--stats: macOS ships openrsync
    if args.delete:
        rsync.append("--delete")
    rsync += [src, dst]
    info(" ".join(rsync))
    sys.exit(subprocess.run(rsync).returncode)


def cmd_run(args):
    """Run a command as a short-lived batch job: resources are only held while
    the command executes — the GPU-idle-friendly way to use GPU partitions."""
    command = args.command
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        die("no command given — usage: hpc-alloc run [options] -- CMD ...")
    partition = pick_partition(args)
    cluster = args.cluster

    if args.dry_run:
        # keep the printed command pastable: without --chdir, sbatch runs from
        # $HOME so a relative --output is exact; with --chdir the remote home
        # can't be resolved offline
        logfile = ("$HOME/.hpc-alloc/run-%j.log" if args.chdir
                   else f"{REMOTE_LOG_DIR}/run-%j.log")
    else:
        state = load_state()
        require_setup(state)
        if cluster not in state["clusters"]:
            die(f"cluster '{cluster}' not configured; run: hpc-alloc setup --cluster {cluster}")
        home = remote_home(cluster, state)
        logfile = f"{home}/{REMOTE_LOG_DIR}/run-%j.log"
        if args.chdir and args.chdir.startswith("~"):  # Slurm --chdir doesn't expand ~
            rest = args.chdir[1:].lstrip("/")
            args.chdir = f"{home}/{rest}" if rest else home

    sbatch = resource_args(args, f"{JOB_PREFIX}run", logfile)
    sbatch.append(f"--partition={partition}")
    if args.chdir:
        sbatch.append(f"--chdir={args.chdir}")
    # one arg = a shell command string (operators work); several args = exact argv,
    # so `run -- python -c 'x = 1'` survives with its quoting intact
    sbatch += ["--wrap", command[0] if len(command) == 1 else shlex.join(command)]
    remote_cmd = submit_prefix() + " ".join(shlex.quote(a) for a in sbatch)
    if args.dry_run:
        print(remote_cmd)
        if args.chdir:
            info("dry-run note: the real submission resolves --output under your remote $HOME")
        return

    jobid = submit_job(cluster, remote_cmd)
    logpath = f"{REMOTE_LOG_DIR}/run-{jobid}.log"
    if args.detach:
        info(f"submitted run job {jobid} on {partition} ({args.time} limit, log: ~/{logpath})")
        info(f"follow with `hpc-alloc logs {jobid} -f`, cancel with `hpc-alloc cancel {jobid}`")
        return
    info(f"submitted run job {jobid} on {partition} ({args.time} limit, log: ~/{logpath}); "
         "Ctrl-C cancels it")
    stream_job(cluster, jobid, logpath, cancel_on_interrupt=True, verdict=True)


def stream_job(cluster, jobid, logpath, cancel_on_interrupt=False, verdict=False):
    """Follow a batch job: show queue progress and stream its log. Ctrl-C/SIGTERM
    detaches; it cancels the job ONLY for `run` (which documents that) — `logs -f`
    must never kill what it is merely watching. verdict=True (run) additionally
    mirrors the job's final exit code and refuses to claim success without a
    FINAL accounting record; watchers (logs -f) always exit 0 after a clean
    stream — watching succeeded regardless of how the watched job ended."""
    offset = 0
    last_note = 0.0
    try:
        while True:
            try:
                live = squeue_query(cluster, [jobid])
                q = live.get(jobid)
                if q and q.state != "RUNNING" and q.state not in ENDED_STATES:
                    # PENDING/SUSPENDED/CONFIGURING/REQUEUED: nothing to tail yet —
                    # say so instead of silently polling a frozen log
                    if time.monotonic() - last_note > 30:
                        note = f"job {jobid}: {q.state}"
                        if q.state == "PENDING" and q.reason:
                            note += f" (reason: {q.reason})"
                        info(note)
                        last_note = time.monotonic()
                    time.sleep(5)
                    continue
                # binary: raw bytes keep the offset exact (no newline translation)
                # and non-UTF-8 log content cannot crash the stream
                r = login_run(cluster,
                              f"tail -c +{offset + 1} {shlex.quote(logpath)} 2>/dev/null || true",
                              check=False, binary=True)
                if r.stdout:
                    sys.stdout.buffer.write(r.stdout)
                    sys.stdout.buffer.flush()
                    offset += len(r.stdout)
            except ConnectionLost as e:
                info(f"connection lost ({e}) — job {jobid} keeps running; log: ~/{logpath}")
                if not can_prompt():
                    die(f"reconnect, then reattach with `hpc-alloc logs {jobid} -f`",
                        code=EXIT_CONNLOST)
                if not wait_reconnect(cluster):
                    die(f"could not reconnect; job {jobid} continues — reattach with "
                        f"`hpc-alloc logs {jobid} -f`", code=EXIT_CONNLOST)
                continue
            if q is None or q.state in ENDED_STATES:
                break
            time.sleep(3)
    except KeyboardInterrupt:
        print()
        if not cancel_on_interrupt:
            info(f"detached — job {jobid} keeps running (reattach: `hpc-alloc logs {jobid} -f`, "
                 f"cancel: `hpc-alloc cancel {jobid}`)")
            sys.exit(130)
        info(f"cancelling job {jobid}")
        try:
            ok, detail = cancel_job(cluster, jobid)
        except SystemExit:  # ensure_login die()d: its own diagnosis is already on stderr
            ok, detail = False, "see the error above"
        if not ok:
            info(f"could not cancel ({detail}) — run `hpc-alloc cancel {jobid}` later")
        sys.exit(130)

    # One last read: epilog output lands after the loop's final poll.
    try:
        r = login_run(cluster, f"tail -c +{offset + 1} {shlex.quote(logpath)} 2>/dev/null || true",
                      check=False, binary=True)
        if r.stdout:
            sys.stdout.buffer.write(r.stdout)
            sys.stdout.buffer.flush()
    except ConnectionLost:
        pass

    if not verdict:
        # Pure watcher: report the outcome if cheaply available, but the stream
        # itself succeeded — exit 0 (a purged accounting record is not a failure).
        try:
            fin = final_job_state(cluster, jobid, patience=False)
            if fin:
                info(f"job {jobid} ended: {fin[0]}")
        except ConnectionLost:
            pass
        return

    # run's contract: never report success without a FINAL accounting record.
    lost = False
    fin = None
    try:
        fin = final_job_state(cluster, jobid)
    except ConnectionLost:
        lost = True
    if fin:
        jstate, exitcode = fin
        code = int(exitcode.split(":")[0]) if ":" in exitcode else 0
        if jstate.split()[0].rstrip("+") != "COMPLETED" and code == 0:
            code = 1  # OOM/TIMEOUT/CANCELLED/NODE_FAIL/... must not read as success
        info(f"job {jobid} finished: {jstate} (exit {code})")
        sys.exit(code)
    if lost:
        die(f"job {jobid} ended but the connection dropped before its final state was "
            f"fetched — check `hpc-alloc why {jobid}`", code=EXIT_CONNLOST)
    die(f"job {jobid} left the queue but accounting shows no FINAL state after ~30s — "
        f"check `hpc-alloc why {jobid}` (not reporting success without evidence)")


def cmd_logs(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    target = args.target
    if target in state["allocs"]:
        alloc = state["allocs"][target]
        cluster, jobid = alloc["cluster"], alloc["jobid"]
        logpath = f"{REMOTE_LOG_DIR}/{jobid}.log"
    elif target.isdigit():
        jobid = target
        cluster, q0 = locate_job(state, jobid, cluster)
        probe_cmd = (f'for f in {REMOTE_LOG_DIR}/run-{jobid}.log {REMOTE_LOG_DIR}/{jobid}.log; '
                     'do [ -f "$f" ] && echo "$f" && break; done')
        r = login_run(cluster, probe_cmd, check=False)
        logpath = r.stdout.strip()
        if not logpath and q0 is None:  # ended job: its log may live on another cluster
            for c in state.get("clusters", {}):
                if c == cluster:
                    continue
                r = login_run(c, probe_cmd, check=False)
                if r.stdout.strip():
                    cluster, logpath = c, r.stdout.strip()
                    break
        logpath = logpath or f"{REMOTE_LOG_DIR}/run-{jobid}.log"
    else:
        die(f"'{target}' is neither an allocation name nor a job id")
    if args.follow:
        stream_job(cluster, jobid, logpath)  # Ctrl-C detaches; never cancels
        return
    r = login_run(cluster, f"tail -n {args.lines} {shlex.quote(logpath)}", check=False, binary=True)
    if r.returncode != 0:
        die(f"no log at ~/{logpath} on {cluster}: {r.stderr.strip()}")
    sys.stdout.buffer.write(r.stdout)
    sys.stdout.buffer.flush()


def cmd_cancel(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    jobid = args.jobid
    if not jobid.isdigit():
        die(f"'{jobid}' is not a job id (for named allocations use `hpc-alloc down NAME`)")
    cluster, q = locate_job(state, jobid, cluster)
    if q is None:
        r = login_run(cluster, f"sacct -j {jobid} -X -n -P -o JobName", check=False)
        jname = (r.stdout.strip().splitlines() or [""])[0]
        if jname.startswith(JOB_PREFIX):
            info(f"job {jobid} has already finished")
            return
        die(f"job {jobid} not found among your jobs")
    if not q.name.startswith(JOB_PREFIX):
        die(f"refusing: job {jobid} ('{q.name}') was not created by hpc-alloc")
    ok, detail = cancel_job(cluster, jobid)
    if not ok:
        die(f"scancel failed for job {jobid}: {detail} — retry")
    with locked_state() as st:
        for n, a in list(st["allocs"].items()):
            if a["jobid"] == jobid and a["cluster"] == cluster:
                if a.get("node"):
                    close_master(alloc_alias(a))
                del st["allocs"][n]
    info(f"cancelled job {jobid}")


def cmd_down(args):
    state = load_state()
    require_setup(state)
    names = list(state["allocs"]) if args.all else [args.name or pick_alloc(state, None)["name"]]
    if not names:
        info("no active allocations")
        return
    failed = 0
    for name in names:
        alloc = state["allocs"].get(name)
        if not alloc:
            info(f"no allocation named '{name}'")
            continue
        ok, detail = cancel_job(alloc["cluster"], alloc["jobid"])
        if not ok:
            info(f"scancel FAILED for job {alloc['jobid']} ('{name}'): {detail} "
                 "— keeping it in state, retry later")
            failed += 1
            continue
        if alloc.get("node"):
            close_master(alloc_alias(alloc))
        with locked_state() as st:
            cur = st["allocs"].get(name)
            if cur and cur.get("jobid") == alloc["jobid"]:  # don't pop a concurrent replacement
                del st["allocs"][name]
        info(f"cancelled job {alloc['jobid']} ('{name}')")
    if failed:
        sys.exit(1)  # scripts must not read a failed release as success


def cmd_connect(args):
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    if args.reset:
        heal_connections(state, cluster)
        info("closed login and compute-node master connections; swept dead sockets")
    if args.push and not try_login(cluster, interactive=False):
        if _last_probe == "auth":
            push_login(cluster)
        # 'net'/'hostkey': a push cannot help — fall through to ensure_login,
        # whose diagnosis (VPN down / host key changed) is the accurate one.
    ensure_login(cluster)
    r = login_run(cluster, "hostname")
    info(f"login OK: {r.stdout.strip()} (multiplexed — no Duo again for ~4h of idle)")
    for name, alloc in sorted(state["allocs"].items()):
        if alloc["cluster"] != cluster or not alloc.get("node"):
            continue
        alias = alloc_alias(alloc)
        st = probe(alias)
        if st != "ok":
            close_master(alias)
            st = probe(alias)
        if st == "ok":
            info(f"node {alloc['node']} ('{name}'): OK")
        elif st == "hostkey":
            info(f"node {alloc['node']} ('{name}'): HOST KEY CHANGED — verify (reimage vs "
                 f"interception), then remove its entry from {KNOWN_HOSTS}")
        else:
            info(f"node {alloc['node']} ('{name}'): unreachable — allocation may have ended; "
                 "run `hpc-alloc status`")


def cmd_partitions(args):
