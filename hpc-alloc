class ClusterError(Exception):
    """Base: the cluster could not answer. Subclasses say WHY, because the
    remedies are disjoint — healing SSH masters fixes transport problems and
    does nothing for scheduler ones (conflating them caused infinite reconnect
    loops and needless master teardowns)."""


class ConnectionLost(ClusterError):
    """SSH transport to the cluster failed or stalled (VPN drop, sleep/wake...).
    Remedy: heal masters, re-auth (exit 3 tells the user to run `connect`)."""


class SlurmError(ClusterError):
    """Transport is fine but Slurm itself failed to answer (slurmctld down,
    squeue erroring, cluster-side hang). Re-auth CANNOT help; retry later."""


# Patience for scheduler errors in polling loops (seconds). Overridable so the
# test suite can exercise the give-up path without a 2-minute wait.
SLURM_RETRY_BUDGET = int(os.environ.get("HPC_ALLOC_SLURM_RETRY_BUDGET", "120"))


class SlurmRetry:
    """Bounded patience for SlurmError inside polling loops. The deadline is set
    at the FIRST error and never extended by further errors — only a successful
    query clears it. (A loop that re-enters its retry path must not live forever;
    that exact bug kept `up` spinning while slurmctld was down.)"""

    def __init__(self, budget=None):
        self.budget = budget or SLURM_RETRY_BUDGET
        self.deadline = None

    def ok(self):
        self.deadline = None

    def wait_or_die(self, cluster, err):
        now = time.monotonic()
        if self.deadline is None:
            self.deadline = now + self.budget
        if now >= self.deadline:
            die(f"Slurm on {cluster} kept erroring for {self.budget}s ({err}).\n"
                "  This is a scheduler problem, not a connection problem — `hpc-alloc connect`\n"
                "  won't help. Submitted jobs are safe; retry once the cluster recovers.")
        info(f"Slurm error on {cluster} ({err}) — retrying...")
        time.sleep(min(10, max(1, self.budget // 12)))


def info(msg):
    # stderr: stdout is reserved for payload (--json, logs, tables) — a stale-
    # master or requeue notice must never corrupt machine-parsed output.
    # flush: backgrounded/piped runs (e.g. agents) must see progress promptly.
    print(f"hpc-alloc: {msg}", file=sys.stderr, flush=True)


def die(msg, code=1):
    print(f"hpc-alloc: error: {msg}", file=sys.stderr)
    sys.exit(code)


