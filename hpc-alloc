def cmd_avail(args):
    """Digest of free capacity: idle CPUs and free GPUs by type, per partition."""
    state = load_state()
    require_setup(state)
    fmt = "Partition:30,StateCompact:12,NodeHost:30,Gres:60,GresUsed:60,CPUsState:30"
    r = login_run(args.cluster, f"sinfo -h -N -O '{fmt}'")
    parts = {}
    for line in r.stdout.splitlines():
        f = line.split()
        if len(f) < 6:
            continue
        pname, nstate, _node, gres, gresused, cpus = f[0].rstrip("*"), f[1], f[2], f[3], f[4], f[5]
        if args.partition and pname != args.partition:
            continue
        p = parts.setdefault(pname, {"nodes": {"idle": 0, "mix": 0, "alloc": 0, "other": 0},
                                     "cpus_idle": 0, "cpus_total": 0, "gpus": {}})
        cls = classify_node_state(nstate)
        p["nodes"][cls] += 1
        if cls == "other":  # drained/down/maint nodes don't contribute capacity
            continue
        try:
            _a, i, _o, t = (int(x) for x in cpus.split("/"))
        except ValueError:
            i = t = 0
        p["cpus_idle"] += i
        p["cpus_total"] += t
        for typ, n in parse_gres(gres):
            p["gpus"].setdefault(typ, {"total": 0, "used": 0})["total"] += n
        for typ, n in parse_gres(gresused):
            p["gpus"].setdefault(typ, {"total": 0, "used": 0})["used"] += n
    for p in parts.values():
        for g in p["gpus"].values():
            g["free"] = g["total"] - g["used"]
    if args.json:
        print(json.dumps({"partitions": parts}, indent=2))
        return
    if not parts:
        info("no matching partitions")
        return
    fmt = "{:<14} {:<22} {:<16} {}"
    print(fmt.format("PARTITION", "NODES idle/mix/alloc/off", "CPUS free/total", "GPUS free/total"))
    for pname, p in sorted(parts.items()):
        n = p["nodes"]
        gpus = "  ".join(f"{t} {g['free']}/{g['total']}" for t, g in sorted(p["gpus"].items())) or "-"
        print(fmt.format(pname, f"{n['idle']}/{n['mix']}/{n['alloc']}/{n['other']}",
                         f"{p['cpus_idle']}/{p['cpus_total']}", gpus))


def cmd_config(args):
    """Show effective defaults (config.toml merged over built-ins). No network."""
    builtins = {
        "partition": DEFAULT_PARTITION, "gpu_partition": DEFAULT_GPU_PARTITION,
        "time": DEFAULT_TIME, "cpus": DEFAULT_CPUS, "mem": None,
        "idle_timeout": DEFAULT_GPU_IDLE_MINUTES,
    }
    cluster = args.cluster  # filled by resolve_common; per-cluster overrides apply
    v = cfg("defaults", "cluster")
    defaults = {"cluster": {"value": v or DEFAULT_CLUSTER,
                            "source": "config" if v else "builtin"}}
    for key, builtin in builtins.items():
        value, source = resolve_option(key, cluster, builtin)
        defaults[key] = {"value": value, "source": source}
    ident = cfg("ssh", "identity_file")
    out = {
        "config_file": str(CONFIG_TOML),
        "config_exists": CONFIG_TOML.exists(),
        "config_error": CONFIG_ERROR,
        "for_cluster": cluster,
        "defaults": defaults,
        "ssh_identity_file": ident,
        "cluster_overrides": cfg("cluster", default={}),
    }
    if args.json:
        print(json.dumps(out, indent=2))
        return
    if CONFIG_ERROR:
        info(f"WARNING: {CONFIG_ERROR} — everything below is built-in defaults")
    info(f"config file: {CONFIG_TOML}"
         + ("" if out["config_exists"] else " (absent — all values are built-ins)")
         + f" — effective for cluster '{cluster}'")
    for key, d in defaults.items():
        val = d["value"] if d["value"] is not None else "(Slurm default: 5120MB per CPU)"
        print(f"  {key:<15} {str(val):<28} [{d['source']}]")
    print(f"  {'identity_file':<15} "
          f"{ident or '(not pinned — ssh offers every key)':<28} "
          f"[{'config' if ident else 'builtin'}]")
    for cname, over in sorted((out["cluster_overrides"] or {}).items()):
        if not isinstance(over, dict):  # e.g. `[cluster]` with `bouchet = "host"`
            print(f"  cluster.{cname}: IGNORED — expected a [cluster.{cname}] table, "
                  f"got {over!r}")
            continue
        if not over:  # section exists but everything is commented out
            continue
        pairs = ", ".join(f"{k}={v}" for k, v in over.items())
        print(f"  cluster.{cname}: {pairs}")


def cmd_why(args):
    """One-shot diagnosis of a pending, running, or dead job."""
    state = load_state()
    require_setup(state)
    cluster = args.cluster
    target = args.target
    name = None
    if target and target in state["allocs"]:
        alloc = state["allocs"][target]
        name, jobid, cluster = target, alloc["jobid"], alloc["cluster"]
    elif target and target.isdigit():
        jobid = target
        cluster, _ = locate_job(state, jobid, cluster)  # ids are per-cluster
    elif not target:
        alloc = pick_alloc(state, None)
        name, jobid, cluster = alloc["name"], alloc["jobid"], alloc["cluster"]
    else:
        die(f"'{target}' is neither an allocation name nor a job id")

    queue = squeue_all(cluster)
    q = queue.get(jobid)
    result = {"jobid": jobid, "name": name, "cluster": cluster}
    detail = []
    if q and q.state not in ENDED_STATES:
        st_, node, reason, left, part = q.state, q.node, q.reason, q.time_left, q.partition
        result.update(status=st_, partition=part, node=node or None,
                      time_left=left, reason=reason)
        if st_ == "PENDING":
            if reason.startswith(("QOSMax", "QOSGrp", "AssocGrp", "MaxTRESPer", "QOSUsage")):
                result["diagnosis"] = (f"a per-user/group resource cap ({reason}) — this will not "
                                       "start until your other jobs release resources")
                mine = [f"{j} ({t.partition}, {t.state}, '{t.name}')" for j, t in sorted(queue.items())
                        if t.state == "RUNNING"]
                detail.append("your running jobs: " + (", ".join(mine) or "none visible"))
            elif "ReqNodeNotAvail" in reason or "Reserv" in reason:
                result["diagnosis"] = ("required nodes are reserved (usually an upcoming "
                                       "maintenance window) — a shorter --time that finishes "
                                       "before the window may start immediately")
                r = login_run(cluster, "scontrol -o show reservation", check=False)
                detail += r.stdout.strip().splitlines()[:5]
            else:
                result["diagnosis"] = f"normal queue contention ({reason})"
                r = login_run(cluster, f"squeue -j {jobid} --start -h -o '%S'", check=False)
                est = r.stdout.strip()
                if est and est != "N/A":
                    detail.append(f"scheduler's estimated start: {est}")
                r = login_run(cluster, f"sprio -l -j {jobid}", check=False)
                detail += r.stdout.strip().splitlines()[:3]
        elif st_ == "RUNNING":
            note = f"running on {node}, {left} left"
            if expiring(st_, left):
                note += " — EXPIRING SOON, sync results out"
            result["diagnosis"] = note
        else:  # SUSPENDED/CONFIGURING/REQUEUED/... — do not claim it is running
            result["diagnosis"] = (f"{st_} — not running right now "
                                   f"(node: {node or 'none assigned'}, {left} on the clock)")
    else:
        result["status"] = "ended"
        rec = sacct_final(cluster, jobid,
                          fields=("State", "ExitCode", "Elapsed", "Timelimit"),
                          attempts=(0, 2, 2))
        if rec:
            jstate, exitcode, elapsed, limit = rec[0], rec[1], rec[2], rec[3]
            result.update(final_state=jstate, exit_code=exitcode, elapsed=elapsed)
            if jstate == "TIMEOUT":
                result["diagnosis"] = f"hit its walltime limit ({elapsed} of {limit})"
            elif jstate == "OUT_OF_MEMORY":
                result["diagnosis"] = "ran out of memory — request more with --mem"
            elif jstate.startswith("CANCELLED"):
                by = jstate.partition("by")[2].strip()
                result["diagnosis"] = (f"cancelled by uid {by} — if that isn't you, it was YCRC "
                                       "staff or the idle-GPU daemon" if by else "cancelled")
            elif jstate == "COMPLETED":
                result["diagnosis"] = ("exited normally (for a GPU allocation this can be the "
                                       "idle watchdog self-releasing — check the log)")
            else:
                result["diagnosis"] = f"{jstate} (exit {exitcode.split(':')[0]})"
            r = login_run(cluster,
                          f"tail -n 15 {REMOTE_LOG_DIR}/run-{jobid}.log "
                          f"{REMOTE_LOG_DIR}/{jobid}.log 2>/dev/null || true", check=False)
            tail = [l for l in r.stdout.strip().splitlines() if not l.startswith("==>")]
            if tail:
                detail += ["--- log tail ---"] + tail[-15:]
        else:
            result["diagnosis"] = ("no FINAL accounting record — a just-ended job can lag a "
                                   "few seconds (retry), or the id is unknown/purged")
    result["detail"] = detail
    if args.json:
        print(json.dumps(result, indent=2))
        return
    label = f"job {jobid}" + (f" ('{name}')" if name else "")
    info(f"{label}: {result.get('status', '?')} — {result['diagnosis']}")
    for line in detail:
        print(f"  {line}")


# ------------------------------------------------------------------- main

def add_resource_flags(sp):
    sp.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    sp.add_argument("-p", "--partition", help=f"Slurm partition (default: {DEFAULT_PARTITION}, "
                                              f"or {DEFAULT_GPU_PARTITION} if --gpus is set)")
    sp.add_argument("-t", "--time", help=f"walltime, Slurm format (default: {DEFAULT_TIME})")
    sp.add_argument("-c", "--cpus", type=int, help=f"CPUs (default: {DEFAULT_CPUS})")
    sp.add_argument("--mem", help="memory per node, e.g. 64G (default: 5120MB per CPU)")
    sp.add_argument("-G", "--gpus", help="GPUs, e.g. 1 or h200:1 or rtx_5000_ada:2")
    sp.add_argument("-C", "--constraint", help="node feature constraint, e.g. 'h200|b200'")
    sp.add_argument("--dry-run", action="store_true", help="print the sbatch command and exit")


def main():
    p = argparse.ArgumentParser(
        prog="hpc-alloc",
        description=__doc__.splitlines()[0],
        epilog=PARTITION_CHEATSHEET,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("setup", help="one-time configuration (NetID, SSH key, ssh_config)")
    sp.add_argument("--netid", help="Yale NetID")
    sp.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    sp.add_argument("--host", help="login hostname (default: <cluster>.ycrc.yale.edu)")
    sp.set_defaults(func=cmd_setup)

    up = sub.add_parser("up", help="allocate a compute node (sbatch sleeper job)",
                        epilog=PARTITION_CHEATSHEET,
                        formatter_class=argparse.RawDescriptionHelpFormatter)
    up.add_argument("--name", default="dev", help="allocation name / ssh alias suffix (default: dev)")
    add_resource_flags(up)
    up.add_argument("--idle-timeout", type=int, metavar="MIN",
                    help="minutes of GPU idleness before the allocation self-releases "
                         f"(GPU allocs only; default {DEFAULT_GPU_IDLE_MINUTES}, 0 disables)")
    up.add_argument("--no-wait", action="store_true", help="submit and return; don't wait for the node")
    up.add_argument("--wait-timeout", type=int, default=1800, help="max seconds to wait (default: 1800)")
    up.set_defaults(func=cmd_up)

    rn = sub.add_parser("run", help="run a command as a short-lived batch job (GPUs held only "
                                    "while it executes); Ctrl-C cancels")
    add_resource_flags(rn)
    rn.add_argument("--chdir", help="remote working directory for the command")
    rn.add_argument("--detach", action="store_true",
                    help="submit and return immediately; follow later with `hpc-alloc logs`")
    rn.add_argument("command", nargs=argparse.REMAINDER, metavar="-- CMD",
                    help="command to run (put after --)")
    rn.set_defaults(func=cmd_run)

    st = sub.add_parser("status", help="show allocations and run jobs (refreshes nodes, aliases, GPU use)")
    st.add_argument("--json", action="store_true", help="machine-readable output")
    st.set_defaults(func=cmd_status)

    av = sub.add_parser("avail", help="free capacity digest: idle CPUs and free GPUs by type per partition")
    av.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    av.add_argument("-p", "--partition", help="limit to one partition")
    av.add_argument("--json", action="store_true", help="machine-readable output")
    av.set_defaults(func=cmd_avail)

    wh = sub.add_parser("why", help="diagnose a job: why pending, how it's doing, or why it died")
    wh.add_argument("target", nargs="?", help="allocation name or job id (default: sole/dev allocation)")
    wh.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    wh.add_argument("--json", action="store_true", help="machine-readable output")
    wh.set_defaults(func=cmd_why)

    sh = sub.add_parser("ssh", help="open a shell (or run a command) on an allocated node")
    sh.add_argument("args", nargs=argparse.REMAINDER, metavar="[NAME] [-- CMD...]",
                    help="allocation name (default: sole allocation, or 'dev'), then optional command")
    sh.set_defaults(func=cmd_ssh)

    sy = sub.add_parser("sync", help="rsync files to (default) or from (--pull) an allocated node")
    sy.add_argument("name", help="allocation name")
    sy.add_argument("src", help="source path")
    sy.add_argument("dst", help="destination path")
    sy.add_argument("--pull", action="store_true", help="copy node -> local instead of local -> node")
    sy.add_argument("--delete", action="store_true", help="pass --delete to rsync")
    sy.set_defaults(func=cmd_sync)

    lg = sub.add_parser("logs", help="show or follow a job's log (allocation name or job id)")
    lg.add_argument("target", help="allocation name or job id")
    lg.add_argument("-f", "--follow", action="store_true",
                    help="stream until the job ends (exit code mirrors the job)")
    lg.add_argument("-n", "--lines", type=int, default=100, help="lines to show (default: 100)")
    lg.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    lg.set_defaults(func=cmd_logs)

    cc = sub.add_parser("cancel", help="cancel an hpc-alloc job by id (refuses foreign jobs)")
    cc.add_argument("jobid", help="Slurm job id (from `hpc-alloc status`)")
    cc.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    cc.set_defaults(func=cmd_cancel)

    dn = sub.add_parser("down", help="cancel allocation(s) and clean up SSH aliases")
    dn.add_argument("name", nargs="?", help="allocation name")
    dn.add_argument("--all", action="store_true", help="cancel all allocations")
    dn.set_defaults(func=cmd_down)

    cf = sub.add_parser("config", help="show effective defaults (config.toml merged over built-ins)")
    cf.add_argument("--cluster", help=f"show values effective for this cluster (default: {DEFAULT_CLUSTER})")
    cf.add_argument("--json", action="store_true", help="machine-readable output")
    cf.set_defaults(func=cmd_config)

    cn = sub.add_parser("connect", help="(re)establish and health-check connections; Duo happens here")
    cn.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    cn.add_argument("--reset", action="store_true", help="tear down all masters and dead sockets first")
    cn.add_argument("--push", action="store_true",
                    help="authenticate via Duo push (no terminal needed — approve on your phone)")
    cn.set_defaults(func=cmd_connect)

    pt = sub.add_parser("partitions", help="list partitions with limits, GRES, and feature tags (sinfo)")
    pt.add_argument("--cluster", help=f"cluster name (default: {DEFAULT_CLUSTER})")
    pt.add_argument("--json", action="store_true", help="machine-readable output")
    pt.set_defaults(func=cmd_partitions)

    args = p.parse_args()
    resolve_common(args)

    def sigterm_to_interrupt(signum, frame):
        # SIGTERM (how agents/task-runners stop a backgrounded run) behaves like
        # Ctrl-C: `run` cancels its job, `up` leaves the queued job with guidance.
        raise KeyboardInterrupt

    signal.signal(signal.SIGTERM, sigterm_to_interrupt)
    try:
        args.func(args)
    except KeyboardInterrupt:
        print()
        sys.exit(130)
    except BrokenPipeError:
        # downstream reader (| head) closed the pipe: not an error, not a traceback
        os.dup2(os.open(os.devnull, os.O_WRONLY), sys.stdout.fileno())
        sys.exit(141)  # 128+SIGPIPE, distinct from job-failure exit codes
    except ConnectionLost as e:
        die(f"lost connection to the cluster ({e}).\n"
            "  Reconnect the VPN if needed, run `hpc-alloc connect` in a terminal, then retry.",
            code=EXIT_CONNLOST)


if __name__ == "__main__":
    main()
