#!/usr/bin/env bash
# Fake ssh for hpc-alloc tests. Behavior is selected via HPCTEST_MODE:
#   down        every connection fails (VPN off / unresolvable)
#   squeue-err  connection fine, slurmctld erroring
#   gone        queue empty (job 9123 finished; sacct says TIMEOUT)
#   running     alloc 9123 + run job 9200 + foreign job 9300 all RUNNING
#   pending-qos 9123 PENDING on a QOS cap
#   expiring    9123 RUNNING with 12 minutes left
#   stale       master looks alive (-O check ok) but commands fail until a heal
#               (-O exit touches $HPCTEST_MARK); then behaves like `running`
#   stale-duo   stale master, and after healing auth needs Duo (askpass marker)
#   flaky       first squeue dies 255, probes fine — must retry WITHOUT healing
#   blip        squeue poll 1 omits job 9123, later polls show it RUNNING
#   flap        job 7777: RUNNING, absent, RUNNING, then gone (via $HPCTEST_COUNT)
#   gpu-fail    like running but nvidia-smi fails (transport stays healthy)
#   tz          cluster clock runs in UTC: submit stamps are cluster-local
#   twocluster  bouchet behaves like `running`; cluster `grace` is unreachable
#               (the offline stand-in for multi-cluster validation — no live
#               second cluster is available)
# scancel and -O exit invocations are appended to $HPCTEST_LOG.
mode="${HPCTEST_MODE:?set HPCTEST_MODE}"
all="$*"

if [ "$mode" = twocluster ]; then
  case "$all" in
    *grace-login*)
      echo "ssh: Could not resolve hostname grace.ycrc.yale.edu" >&2
      exit 255 ;;
  esac
  mode=running  # the bouchet side is a healthy running cluster
fi

case "$all" in
  *"-O exit"*)
    echo "MUXEXIT: $all" >> "${HPCTEST_LOG:-/dev/null}"
    case "$mode" in
      stale) touch "${HPCTEST_MARK:?}" ;;
      stale-duo) touch "${HPCTEST_MARK:?}.heal" ;;
    esac
    exit 0 ;;
  *"-O check"*)
    case "$mode" in
      down|hostkey) echo "no master" >&2; exit 255 ;;
      duo) [ -f "${HPCTEST_MARK:?}" ] && exit 0 || exit 1 ;;
    esac
    exit 0 ;;
esac

if [ "$mode" = down ]; then
  echo "ssh: Could not resolve hostname bouchet.ycrc.yale.edu" >&2
  exit 255
fi

if [ "$mode" = hostkey ]; then
  echo "@@@ WARNING: REMOTE HOST IDENTIFICATION HAS CHANGED! @@@" >&2
  echo "Host key verification failed." >&2
  exit 255
fi

# duo: auth fails until an SSH_ASKPASS attempt "approves" (creates the marker).
# Approval also requires the one-prompt cap — a push attempt that would let ssh
# re-prompt (and re-push) on a denied/expired push must not pass the suite.
if [ "$mode" = duo ] && [ ! -f "${HPCTEST_MARK:?}" ]; then
  case "$all" in
    *"NumberOfPasswordPrompts=1"*)
      if [ -n "${SSH_ASKPASS:-}" ]; then touch "$HPCTEST_MARK"; exit 0; fi ;;
  esac
  echo "ab1234@bouchet.ycrc.yale.edu: Permission denied (keyboard-interactive)." >&2
  exit 255
fi

# stale: every command through the "master" fails until it has been healed
if [ "$mode" = stale ] && [ ! -f "${HPCTEST_MARK:?}" ]; then
  echo "mux_client_request_session: session request failed: Session open refused" >&2
  exit 255
fi

# stale-duo: same, and the fresh connection after healing needs Duo
if [ "$mode" = stale-duo ]; then
  if [ ! -f "${HPCTEST_MARK:?}.heal" ]; then
    echo "mux_client_request_session: session request failed: Session open refused" >&2
    exit 255
  fi
  if [ ! -f "$HPCTEST_MARK" ]; then
    case "$all" in
      *"NumberOfPasswordPrompts=1"*)
        if [ -n "${SSH_ASKPASS:-}" ]; then touch "$HPCTEST_MARK"; exit 0; fi ;;
    esac
    echo "ab1234@bouchet.ycrc.yale.edu: Permission denied (keyboard-interactive)." >&2
    exit 255
  fi
fi

# flaky: the first squeue dies mid-flight; probes and retries succeed
if [ "$mode" = flaky ] && [ ! -f "${HPCTEST_MARK:?}" ]; then
  case "$all" in *squeue*)
    touch "$HPCTEST_MARK"
    echo "packet_write_wait: Connection to bouchet port 22: Broken pipe" >&2
    exit 255 ;;
  esac
fi

bump_count() {  # per-squeue-poll counter for the stateful modes
  n=$(cat "${HPCTEST_COUNT:?}" 2>/dev/null || echo 0)
  echo $((n + 1)) > "$HPCTEST_COUNT"
}

remote_now() {  # the cluster clock appended to every squeue_all round trip
  if [ "$mode" = tz ]; then  # cluster in UTC, client wherever it happens to be
    python3 -c 'import time; print(time.strftime("%Y-%m-%dT%H:%M:%S", time.gmtime()))'
  else
    date +%Y-%m-%dT%H:%M:%S
  fi
}

row() {  # emit one squeue row, fields joined by the US byte (\037)
  local IFS=$'\037'
  printf '%s\n' "$*"
}

squeue_rows() {
  case "$mode" in
    squeue-err) echo "slurm_load_jobs error: Unable to contact slurm controller" >&2; return 1 ;;
    gone) ;;
    running|stale|flaky|gpu-fail)
      h="$(hostname -s)"
      row 9123 RUNNING r806u23n04 None 3:59:00 gpu_h200 hpcalloc-h200 2020-01-01T00:00:00 "hpc-alloc:testid123456:$h"
      row 9200 RUNNING r801u01n01 None 1:00:00 gpu hpcalloc-run 2020-01-01T00:00:00 "hpc-alloc:testid123456:$h"
      row 9300 RUNNING r802u02n02 None 2:00:00 day 'my|job' 2020-01-01T00:00:00 ""
      row 9400 RUNNING r803u03n03 None 5:00:00 day hpcalloc-stale 2020-01-01T00:00:00 "hpc-alloc:testid123456:$h"
      row 9500 RUNNING r804u04n04 None 5:59:00 day hpcalloc-fresh "$(date +%Y-%m-%dT%H:%M:%S)" "hpc-alloc:testid123456:$h"
      row 9600 RUNNING r805u05n05 None 4:00:00 day hpcalloc-dev 2020-01-01T00:00:00 "hpc-alloc:otherid999999:othermachine"
      row 9650 RUNNING r805u05n06 None 4:00:00 day hpcalloc-twin 2020-01-01T00:00:00 "hpc-alloc:otherid999999:$h" ;;
    tz)  # cluster-local (UTC) stamps: 1h-old sleeper + 5s-fresh sleeper
      old=$(python3 -c 'import time; print(time.strftime("%Y-%m-%dT%H:%M:%S", time.gmtime(time.time() - 3600)))')
      new=$(python3 -c 'import time; print(time.strftime("%Y-%m-%dT%H:%M:%S", time.gmtime(time.time() - 5)))')
      row 9700 RUNNING r801u01n01 None 1:00:00 day hpcalloc-old "$old" "hpc-alloc:testid123456:testhost"
      row 9800 RUNNING r802u02n02 None 1:00:00 day hpcalloc-new "$new" "hpc-alloc:testid123456:testhost" ;;
    pending-qos) row 9123 PENDING "" QOSMaxGRESPerUser 8:00:00 gpu_h200 hpcalloc-h200 2020-01-01T00:00:00 "" ;;
    expiring) row 9123 RUNNING r806u23n04 None 0:12:00 gpu_h200 hpcalloc-h200 2020-01-01T00:00:00 "" ;;
    suspended) row 9123 SUSPENDED r806u23n04 None 3:59:00 gpu_h200 hpcalloc-h200 2020-01-01T00:00:00 "" ;;
    blip)  # first poll: job missing; confirm-poll and later: RUNNING
      bump_count
      if [ "$n" -ge 1 ]; then
        row 9123 RUNNING r806u23n04 None 3:59:00 gpu_h200 hpcalloc-h200 2020-01-01T00:00:00 ""
      fi ;;
    flap)  # job 7777: RUNNING, one-poll blip, RUNNING again, then really gone
      bump_count
      case "$n" in
        0|2) row 7777 RUNNING r801u01n01 None 1:00:00 gpu hpcalloc-run 2020-01-01T00:00:00 "" ;;
      esac ;;
  esac
  return 0
}

case "$all" in
  *sbatch*) echo 7777 ;;
  *scancel*)
    echo "SCANCEL: $all" >> "${HPCTEST_LOG:-/dev/null}"
    exit "${HPCTEST_SCANCEL_RC:-0}" ;;
  *"squeue --me"*"printf OK"*)  # stream_job's combined queue+log poll
    squeue_rows || exit 1
    printf 'OK\036'
    if [ "$mode" = flap ] && [ "$(cat "$HPCTEST_COUNT" 2>/dev/null || echo 0)" -ge 3 ]; then
      echo "after-blip"  # content only reachable if the stream survives the blip
    else
      echo "epoch 1: loss 0.42"
    fi ;;
  *"squeue --me"*)
    squeue_rows || exit 1
    printf '\036'; remote_now ;;
  *"--start"*) echo "2026-07-09T18:00:00" ;;
  *sprio*) printf 'JOBID PRIORITY AGE FAIRSHARE\n9123 1200 300 900\n' ;;
  *"show reservation"*)
    echo "ReservationName=maint StartTime=2026-07-12T08:00:00 EndTime=2026-07-12T20:00:00 Nodes=ALL" ;;
  *sacct*)
    # HPCTEST_SACCT_LAG=<counter-file>: emit a stale RUNNING record for the
    # first two queries (simulating slurmdbd commit lag), then the real state.
    if [ -n "${HPCTEST_SACCT_LAG:-}" ]; then
      n=$(cat "$HPCTEST_SACCT_LAG" 2>/dev/null || echo 0)
      echo $((n + 1)) > "$HPCTEST_SACCT_LAG"
      if [ "$n" -lt 2 ]; then echo "RUNNING|0:0"; exit 0; fi
    fi
    if [ "$mode" = gone ]; then echo "TIMEOUT|0:0|8:00:01|8:00:00"
    else echo "COMPLETED|0:0|0:10:00|4:00:00"; fi ;;
  *"sinfo -h -N -O"*)
    cat <<'SINFO'
gpu_h200 mix r801n01 gpu:h200:8 gpu:h200:6(IDX:0-5) 32/32/0/64
gpu_h200 idle r801n02 gpu:h200:8 gpu:h200:0 0/64/0/64
gpu_h200 drain r801n03 gpu:h200:8 gpu:h200:0 0/0/64/64
day alloc r802n01 (null) (null) 64/0/0/64
day idle r802n02 (null) (null) 0/64/0/64
SINFO
    ;;
  *"sinfo -o"*)
    printf 'PARTITION|AVAIL|TIMELIMIT|NODES|CPUS|MEMORY|GRES|AVAIL_FEATURES\n'
    printf 'day*|up|1-00:00:00|76|64|990000|(null)|era,nogpu\n'
    printf 'gpu_h200|up|2-00:00:00|7|64|990000|gpu:h200:8|h200\n' ;;
  *nvidia-smi*)
    if [ "$mode" = gpu-fail ]; then exit 1; fi
    printf '42\n17\n' ;;
  *'printf "%s" "$HOME"'*) printf '/home/ab1234' ;;
  *"for f in"*) echo ".hpc-alloc/run-9200.log" ;;
  *tail*) echo "epoch 1: loss 0.42" ;;
  *hostname*) echo "login1.bouchet" ;;
esac
exit 0
